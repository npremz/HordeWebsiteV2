---
import { DEFAULT_LOCALE, type Locale, useTranslations } from '../../i18n';
import { getServiceSummaries } from '../../lib/content/services';

interface Props {
  lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;
const t = useTranslations(lang);
const services = await getServiceSummaries();

const sectionClass = "py-25 text-white sm:py-50";
const headingClass = "text-[1.5rem] sm:text-[2rem] md:text-[2.5rem] lg:text-[3rem]";
const listOffsetClass = "mt-8 sm:mt-12 md:mt-20";
const rowLinkClass = "service-link flex items-center justify-between pt-8 pb-7 sm:pt-10 sm:pb-9 lg:pt-10 lg:pb-10";
const rowTitleClass = "max-w-[280px] text-[1.25rem] leading-none sm:max-w-[unset] sm:text-[1.5rem] md:text-[2rem]";
---

<section id="services" class={sectionClass}>
  <div class="flex justify-between gap-4">
    <h2 class={headingClass}>{t.homepage.services.title}</h2>
    <svg class="hidden sm:block mt-2 md:mt-4" width="47" height="20" viewBox="0 0 47 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect width="7" height="20" transform="matrix(1 4.37114e-08 8.74228e-08 -1 0 20)" fill="#F4F1F8"/>
      <rect width="7" height="20" transform="matrix(1 4.37114e-08 8.74228e-08 -1 14 20)" fill="#F4F1F8"/>
      <rect width="7" height="20" transform="matrix(0.707107 0.707107 0.707107 -0.707107 27.4531 14.5938)" fill="#F4F1F8"/>
    </svg>
  </div>
  <ol class={listOffsetClass}>
    {services.map((service) => (
      <li class="border-b border-lines-dark last:border-b-0">
        <a
          href={service.url}
          title={service.title}
          class={rowLinkClass}
        >
          <span class:list={['service-link__label', rowTitleClass]}>
            <span class="service-link__label-base">
              {service.title}
            </span>
            <span class="service-link__label-overlay" aria-hidden="true">
              {service.title}
            </span>
          </span>
          <span class="service-link__icon shrink-0 text-[1.375rem]">
            <span class="service-link__icon-base">(→)</span>
            <span class="service-link__icon-overlay" aria-hidden="true">(→)</span>
          </span>
        </a>
      </li>
    ))}
  </ol>
</section>

<style>
  .service-link {
    position: relative;
    isolation: isolate;
  }

  .service-link::before {
    content: "";
    position: absolute;
    top: 10px;
    right: -10px;
    bottom: 10px;
    left: -10px;
    background-color: #FFFFFF;
    z-index: -1;
    transform: scaleY(0);
    transform-origin: center bottom;
  }

  .service-link__label,
  .service-link__icon {
    position: relative;
    z-index: 1;
    display: block;
    overflow: hidden;
  }

  .service-link__icon {
    display: inline-flex;
  }

  .service-link__label-base,
  .service-link__icon-base,
  .service-link__label-overlay,
  .service-link__icon-overlay {
    display: block;
    transition: transform 0.15s ease-out;
  }

  .service-link__label-overlay,
  .service-link__icon-overlay {
    position: absolute;
    inset: 0;
    transform: translateY(100%);
    color: var(--color-black);
  }

  @media (hover: hover) {
    .service-link::before {
      transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .service-link:hover::before {
      transform: scaleY(1);
    }

    .service-link:hover .service-link__label-base,
    .service-link:hover .service-link__icon-base {
      transform: translateY(-100%);
    }

    .service-link:hover .service-link__label-overlay,
    .service-link:hover .service-link__icon-overlay {
      transform: translateY(0);
    }

    .service-link:hover :global(.wrapped) {
      color: inherit !important;
    }
  }
</style>
