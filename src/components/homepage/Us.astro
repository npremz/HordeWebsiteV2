---
import { Image } from 'astro:assets';
import CtaButton from '../ui/actions/CtaButton.astro';

import foundersImg from "../../assets/images/nous-opti.jpg";
import keyboardImg from "../../assets/images/keyboard_a.jpg";
import { DEFAULT_LOCALE, type Locale, useTranslations } from "../../i18n";
import EndpointDivider from '../ui/decor/EndpointDivider.astro';

interface Props {
	lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;
const t = useTranslations(lang);
---

<section id="us" class="py-16 sm:pt-32 md:pt-24 md:mx-5 md:border-x md:border-b md:rounded-b-full md:border-lines">
  <div class="px-5 sm:px-12 lg:px-24">
    <h2 class="section-label">{t.homepage.us.titleLine1}<br/> {t.homepage.us.titleLine2}</h2>
    <p class="indent-24 sm:indent-45 text-[1.5rem] sm:text-[2rem]">{t.homepage.us.description}</p>
    <div class="mt-10 md:mt-16 flex">
      <CtaButton href={`/${lang}/about`} label={t.homepage.us.cta} variant="light" />
    </div>
    <figure
      class="mt-16 sm:mt-24 md:mt-32 md:flex md:gap-16 md:items-center"
      data-us-parallax-gallery
    >
      <Image
        src={foundersImg}
        alt={t.about.foundersAlt}
        class="w-full md:flex-[3] md:min-w-0 h-auto object-cover parallax-img"
        data-speed="0.06"
        loading="lazy"
        decoding="async"
      />
      <Image
        src={keyboardImg}
        alt={t.about.keyboardAlt}
        class="hidden md:block md:flex-[2] md:min-w-0 object-cover parallax-img"
        data-speed="0.12"
        loading="lazy"
        decoding="async"
      />
    </figure>
  </div>
</section>
<EndpointDivider class:list={"mt-5"}/>

<script is:inline>
  (function () {
    if (window.innerWidth < 640) return;

    var images = document.querySelectorAll("[data-us-parallax-gallery] .parallax-img");
    if (!images.length) return;

    var viewportHeight = window.innerHeight;
    var ticking = false;
    var useLenis = false;
    var checkLenisInterval = null;

    function updateParallax() {
      for (var i = 0; i < images.length; i++) {
        var img = images[i];
        var rect = img.getBoundingClientRect();
        if (rect.bottom < 0 || rect.top > viewportHeight) continue;

        var centerOffset = rect.top + rect.height / 2 - viewportHeight / 2;
        var speed = parseFloat(img.dataset.speed || "0.05");
        var translateY = centerOffset * speed * -1;

        img.style.transform = "translateY(" + translateY + "px)";
      }
      ticking = false;
    }

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(updateParallax);
        ticking = true;
      }
    }

    function attachLenis() {
      if (window.lenis && !useLenis) {
        useLenis = true;
        window.removeEventListener("scroll", onScroll);
        window.lenis.on("scroll", onScroll);
        if (checkLenisInterval) clearInterval(checkLenisInterval);
      }
    }

    function cleanup() {
      if (useLenis && window.lenis) {
        window.lenis.off("scroll", onScroll);
      } else {
        window.removeEventListener("scroll", onScroll);
      }
      if (checkLenisInterval) clearInterval(checkLenisInterval);
      document.removeEventListener("astro:before-swap", cleanup);
    }

    updateParallax();

    if (window.lenis) {
      useLenis = true;
      window.lenis.on("scroll", onScroll);
    } else {
      window.addEventListener("scroll", onScroll, { passive: true });
      checkLenisInterval = setInterval(attachLenis, 500);
      setTimeout(function () {
        if (checkLenisInterval) clearInterval(checkLenisInterval);
      }, 5000);
    }

    document.addEventListener("astro:before-swap", cleanup);
  })();
</script>

<style>
  .parallax-img {
    will-change: transform;
  }
</style>
