---
import { Image } from 'astro:assets';
import Button from '../ui/Button.astro';
import ServiceSectionHeading from '../services/ServiceSectionHeading.astro';
import alex from '../../assets/images/alex.jpg';
import nico from '../../assets/images/nico.jpg';

const members = [
  {
    name: 'Alexandre',
    title: 'Alexandre — Designer',
    description:
      "9 ans à transformer des idées floues en interfaces qui répondent à de vrais besoins. Obsédé par les détails et allergique au générique.",
    img: alex,
    alt: 'Alexandre, co-fondateur de Horde',
    reverse: false,
  },
  {
    name: 'Nicolas',
    title: 'Nicolas — Développeur',
    description:
      "9 ans à construire des sites impeccables. La performance, le SEO et la sécurité\u00a0: ce n'est pas négociable.",
    img: nico,
    alt: 'Nicolas, co-fondateur de Horde',
    reverse: true,
  },
];
---

<section id="us" class="pt-25 pb-25">
  <ServiceSectionHeading
    id="us-title"
    left="Deux\ncerveaux,"
    right="Une\nvision"
  />

  <ul class="mt-20 sm:mt-32">
    {members.map((member, i) => (
      <li class:list={["member-item border-t border-lines", i === members.length - 1 && "border-b"]}>
        <div class:list={["flex flex-col sm:flex-row sm:items-stretch", member.reverse && "sm:flex-row-reverse"]}>
          <!-- Photo -->
          <div class="shrink-0 sm:w-[38%] md:w-[30%]">
            <Image
              src={member.img}
              alt={member.alt}
              class="w-full h-60 sm:h-full object-cover"
              widths={[400, 800]}
              sizes="(min-width: 640px) 38vw, 100vw"
              loading="lazy"
              decoding="async"
              format="webp"
              quality={85}
            />
          </div>

          <!-- Content -->
          <div class:list={[
            "flex flex-col justify-between px-6 py-10 sm:py-12 sm:px-10 border-lines",
            member.reverse ? "sm:border-r" : "sm:border-l",
          ]}>
            <div>
              <span class="section-label">/ {String(i + 1).padStart(3, '0')}</span>
              <h3 class="mt-6 font-display uppercase leading-none text-[1.75rem] sm:text-[2rem]">
                {member.title}
              </h3>
              <p class="mt-8 text-[1.25rem] sm:text-[1.5rem] leading-[1.3] indent-12 sm:indent-24 max-w-[52ch]">
                {member.description}
              </p>
            </div>
          </div>
        </div>
      </li>
    ))}
  </ul>

  <div class="mt-16 flex justify-end">
    <Button href="/fr/a-propos" label="En savoir plus sur nous" variant="dark" />
  </div>
</section>
