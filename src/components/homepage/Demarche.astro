---
import { DEFAULT_LOCALE, type Locale, useTranslations } from "../../i18n";

interface Props {
  lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;
const t = useTranslations(lang);
const steps = t.homepage.demarche.steps;

const sectionClass = "py-16 text-black sm:py-24 sm:pb-32 md:pb-50";
const headingClass = "text-[1.5rem] leading-[1.08] sm:pr-8 sm:text-[2rem] md:text-[2.5rem] lg:max-w-1/2 lg:p-0";
const gridClass = "space-y-16 sm:grid sm:grid-cols-2 sm:space-y-0 sm:gap-x-24 md:grid-cols-3 md:gap-x-16";
---

<section id="demarche" class={sectionClass}>
  <div class="relative mb-16 flex flex-col md:mb-24">
    <h2 class={headingClass}>{t.homepage.demarche.title}</h2>
    <svg class="decorative-diagonal-box mt-4 h-6 self-end translate-x-5 sm:absolute sm:right-0 sm:translate-0" width="24" height="24" viewBox="-2 -2 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <g class="decorative-diagonal-spin">
        <rect width="7" height="20" transform="matrix(0.707107 0.707107 0.707107 -0.707107 0 14.1426)" fill="#16191B"/>
      </g>
    </svg>
  </div>

  <div class={gridClass}>
    {steps.map((step) => (
      <article class="flex flex-col">
        <span class="font-mono text-[1rem] leading-none whitespace-nowrap">
          {step.number.padStart(2, "0")}
        </span>
        <div class="flex flex-col w-full mt-5 sm:justify-between">
          <div class="flex justify-between items-end">
            <h3 class="text-[1.5rem] lg:text-[2rem] leading-[1.2]">{step.title}</h3>
          </div>
          <hr class:list={[
            "border-lines",
            "mt-10 md:mt-16"
          ]} />
          <p class="mt-10 md:mt-16 text-[1.125rem] indent-24">{step.description}</p>
        </div>
      </article>
    ))}
  </div>

  <div class="mt-10 sm:mt-16 md:mt-24 sm:grid sm:grid-cols-2 sm:gap-x-24 md:grid-cols-3 md:gap-x-16">
    <a
      href={`/${lang}/contact`}
      class="underline-hover w-fit text-[1.125rem] lg:text-[1.375rem]"
    >
      {t.homepage.demarche.cta} (↗)
    </a>
  </div>
</section>
