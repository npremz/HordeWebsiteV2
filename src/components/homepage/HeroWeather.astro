---
import { DEFAULT_LOCALE, type Locale, useTranslations } from "../../i18n";

interface Props {
  lang?: Locale;
  class?: string;
}

const { lang = DEFAULT_LOCALE, class: className = "" } = Astro.props;
const t = useTranslations(lang);
---

<div
  class:list={[
    "hero-weather-widget flex flex-col gap-1 font-mono text-[0.875rem] leading-tight uppercase",
    className,
  ]}
>
  <span class="hero-weather-time" data-days={JSON.stringify(t.hero.days)}
    >--- (--:--:--)</span
  >
  <span
    class="hero-weather-current"
    data-weather-codes={JSON.stringify(t.hero.weatherCodes)}
    >BXL --° <span
      class="font-neuebit text-[1.75rem] inline-block leading-[0] relative -top-[-3px]"
      >☁</span
    ></span
  >
</div>

<script>
  const weatherIcons: Record<number, string> = {
    0: "☀",
    1: "⛅",
    2: "☁",
    3: "☁",
    45: "☁",
    48: "☁",
    51: "☂",
    53: "☂",
    55: "☂",
    61: "☂",
    63: "☂",
    65: "☂",
    71: "❄",
    73: "❄",
    75: "❄",
    77: "❄",
    80: "☂",
    81: "☂",
    82: "☂",
    95: "⚡",
    96: "⚡",
    99: "⚡",
  };

  let timeIntervalId: number | null = null;
  let weatherIntervalId: number | null = null;

  function formatDateTime(date: Date, days: string[]) {
    const dayName = days[date.getDay()];
    const day = date.getDate().toString().padStart(2, "0");
    const month = (date.getMonth() + 1).toString().padStart(2, "0");
    const hours = date.getHours().toString().padStart(2, "0");
    const minutes = date.getMinutes().toString().padStart(2, "0");
    const seconds = date.getSeconds().toString().padStart(2, "0");

    return `${dayName} (${hours}:${minutes}:${seconds})`;
  }

  function updateTimes() {
    document.querySelectorAll<HTMLElement>(".hero-weather-time").forEach((timeEl) => {
      const daysData = timeEl.dataset.days;
      const days = daysData
        ? JSON.parse(daysData)
        : ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];

      timeEl.textContent = formatDateTime(new Date(), days);
    });
  }

  async function fetchWeather() {
    const weatherEls = document.querySelectorAll<HTMLElement>(".hero-weather-current");
    if (!weatherEls.length) return;

    try {
      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 5000);

      const response = await fetch(
        "https://api.open-meteo.com/v1/forecast?latitude=50.8503&longitude=4.3517&current_weather=true",
        { signal: controller.signal },
      );
      clearTimeout(timeoutId);

      const data = await response.json();
      const temp = Math.round(data.current_weather.temperature);
      const code = data.current_weather.weathercode;
      const weatherIcon = weatherIcons[code] || "☁";

      weatherEls.forEach((weatherEl) => {
        const weatherCodesData = weatherEl.dataset.weatherCodes;
        const weatherCodes: Record<number, string> = weatherCodesData
          ? JSON.parse(weatherCodesData)
          : {};
        const weatherLabel = weatherCodes[code] || "--";

        weatherEl.innerHTML = `${temp}° ${weatherLabel} <span class="font-neuebit text-[1.75rem] inline-block leading-[0] relative -top-[-3px]">${weatherIcon}</span>`;
      });
    } catch {
      // Keep placeholders on error.
    }
  }

  function cleanupHeroWeather() {
    if (timeIntervalId) {
      clearInterval(timeIntervalId);
      timeIntervalId = null;
    }

    if (weatherIntervalId) {
      clearInterval(weatherIntervalId);
      weatherIntervalId = null;
    }
  }

  function initHeroWeather() {
    cleanupHeroWeather();
    updateTimes();
    fetchWeather();

    timeIntervalId = window.setInterval(updateTimes, 1000);
    weatherIntervalId = window.setInterval(fetchWeather, 1000 * 60 * 15);
  }

  if (document.readyState === "complete") {
    initHeroWeather();
  } else {
    window.addEventListener("load", initHeroWeather, { once: true });
  }

  document.addEventListener("astro:after-swap", () => {
    setTimeout(initHeroWeather, 50);
  });
</script>
