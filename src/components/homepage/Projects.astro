---
import { DEFAULT_LOCALE, type Locale, useTranslations } from '../../i18n';
import { getLocalizedProjects } from '../../lib/content/projects';

interface Props {
  lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;
const t = useTranslations(lang);
const projects = (await getLocalizedProjects(lang)).slice(0, 3);
---

<section id="projects" class="pt-25 sm:py-50 md:pb-80 lg:pb-120 sm:mx-5 sm:border-x sm:overflow-hidden sm:border-b sm:rounded-b-full sm:border-lines">
  <h2 class="font-mono text-[14px] uppercase text-center">{t.homepage.projects.countLabel} ({projects.length.toString().padStart(2, '0')})</h2>
  <ul class="mt-6 font-display uppercase text-[2.25rem] sm:text-[4rem] md:text-[5rem] text-center">
    {projects.map((project, i) => (
      <>
        {i > 0 && <li aria-hidden="true" class="h-px bg-lines"></li>}
        <li class="py-4 sm:py-5 lg:py-6">
          <a
            href={`/${lang}/projets/${project.slug}`}
            class="project-home-link relative inline-block overflow-hidden"
          >
            <span class="project-home-link__text relative z-10 block">{project.shortTitle}</span>
          </a>
        </li>
      </>
    ))}
  </ul>
</section>

<style>
  .project-home-link::before {
    content: "";
    position: absolute;
    inset: 0;
    background-color: #FFFFFF;
    transform: scaleY(0);
    transform-origin: center bottom;
  }

  @media (hover: hover) {
    .project-home-link::before {
      transition: transform 0.25s ease-out;
    }

    .project-home-link__text {
      transition: color 0.15s ease-out;
    }

    .project-home-link:hover::before {
      transform: scaleY(1);
    }

    .project-home-link:hover .project-home-link__text {
      color: var(--color-black);
    }
  }
</style>
