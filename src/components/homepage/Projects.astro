---
import { DEFAULT_LOCALE } from '../../i18n';
import { getLocalizedProjects } from '../../lib/content/projects';

const lang = DEFAULT_LOCALE;

const projects = (await getLocalizedProjects(lang)).slice(0, 3);
---

<section id="projects" class="mt-25">
  <h2 class="section-label text-center">sites web realisés ({projects.length.toString().padStart(2, '0')})</h2>
  <ul class="mt-10 font-display uppercase text-[2.25rem] text-center">
    {projects.map((project, i) => (
      <>
        {i > 0 && <li aria-hidden="true" class="h-px bg-lines"></li>}
        <li class="py-10">
          <a href={`/${lang}/projets/${project.slug}`}>{project.shortTitle}</a>
        </li>
      </>
    ))}
  </ul>
</section>
