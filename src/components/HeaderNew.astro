---
import {
  DEFAULT_LOCALE,
  type Locale,
  useTranslations,
  getLocalizedPath,
  getPathWithoutLocale,
} from "../i18n";
import { getNavigation } from "../lib/site-data";

interface Props {
  lang?: Locale;
  alternateUrl?: string; // URL explicite pour l'autre langue (slugs différents FR/EN)
  theme?: 'light' | 'dark';
}

const { lang = DEFAULT_LOCALE, alternateUrl, theme } = Astro.props;
const isDark = theme === 'dark';
const textColorClass = isDark ? 'text-white' : '';
const svgFill = isDark ? '#FFFFFF' : '#16191B';
const t = useTranslations(lang);

// Get current path for language switcher
const currentPath = getPathWithoutLocale(Astro.url.pathname);
const switchLang = lang === "fr" ? "en" : "fr";
// Utiliser alternateUrl si fourni, sinon calculer automatiquement
const switchUrl = alternateUrl || getLocalizedPath(currentPath, switchLang);

const navigation = await getNavigation(lang);
const { logoAlt = "Logo", items = [] } = navigation;
const email = "hello@hordeagence.com";
---

<!-- ============================================================ -->
<!-- DESKTOP header (>= 1024px) — fixed, remplacé par le relay  -->
<!-- ============================================================ -->
<div
  id="header-desktop"
  class="header-desktop hidden lg:block fixed top-0 left-0 right-0 z-[9999998] pointer-events-none"
>
  <div class:list={["hidden lg:grid lg:grid-cols-3 pointer-events-none px-8 py-6", textColorClass]}>

    <!-- Col 1 — CTA gauche -->
    <div class="flex h-fit">
      <a
        href={`/${lang}/contact`}
        id="header-start-project"
        class="flex items-center gap-2.5 text-[1.375rem] pointer-events-auto"
        data-text={t.nav.startProject}
        title={t.nav.startProject}
      >
        <svg
          width="11"
          height="10"
          viewBox="0 0 11 10"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path
            d="M7.38206 10L6.60058 9.24904L9.13314 6.39847L0 6.39847V0H1V5.32567H9.13314L6.60058 2.4751L7.38206 1.72414L11 5.86207L7.38206 10Z"
            fill={svgFill}></path>
        </svg>
        <span class="nav-scramble-header">{t.nav.startProject}</span>
      </a>
    </div>

    <!-- Col 2 — Logo full centré -->
    <div class="flex justify-center">
      <a href={`/${lang}`} title={logoAlt} class="pointer-events-auto">
        <img
          src="/images/logo_full.svg"
          class:list={["py-2.5", isDark && "invert"]}
          alt={logoAlt}
          width="320"
          height="15"
          decoding="async"
          fetchpriority="high"
        />
      </a>
    </div>

    <!-- Col 3 — Nav verticale droite -->
    <div class="flex justify-end">
      <nav aria-label="Navigation principale" class="pointer-events-auto">
        <ul class="flex flex-col items-end gap-[10px]">
          {
            items.map((item) => (
              <li>
                <a
                  href={item.url}
                  class="header-link text-[1rem] lg:text-[1.375rem] leading-none hover:opacity-60 transition-opacity duration-200"
                  target={item.isExternal ? "_blank" : undefined}
                  rel={item.isExternal ? "noopener noreferrer" : undefined}
                  title={item.label}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
          <li>
            <a
              href={switchUrl}
              hreflang={switchLang}
              title={t.nav.switchLang}
              class="text-[1rem] font-mono uppercase leading-none hover:opacity-60 transition-opacity duration-200"
            >
              {switchLang.toUpperCase()}
            </a>
          </li>
        </ul>
      </nav>
    </div>

  </div>
</div>
<!-- /DESKTOP -->

<!-- ============================================================ -->
<!-- RELAY header (mobile-style) — toujours fixed sur mobile,   -->
<!-- slide in sur desktop quand le desktop header disparaît      -->
<!-- ============================================================ -->
<header
  id="header-new"
  class="header-new fixed z-[9999999] top-0 left-0 right-0 pointer-events-none"
>

  <div class="sm:max-w-[85%] sm:mx-auto pt-(--gutter) sm:pt-4 px-(--gutter)">

    <!-- Header bar -->
    <div class="header-bar bg-white px-5 py-4 pointer-events-none" style="box-shadow: 0px 4px 8.1px rgba(0, 0, 0, 0.1);">
      <div class="flex-between">
        <!-- Logo -->
        <a href={`/${lang}`} class="block pointer-events-auto" title={logoAlt}>
          <img
            src="/images/logo.svg"
            alt={logoAlt}
            class="h-[17px] w-auto sm:h-auto sm:w-18"
            width="112"
            height="40"
            decoding="async"
            fetchpriority="high"
          />
        </a>

        <!-- Menu button -->
        <button
          type="button"
          id="menu-toggle-new"
          class="flex-center gap-4 cursor-pointer pointer-events-auto"
          aria-expanded="false"
          aria-controls="menu-panel"
          aria-label={t.nav.openMenu}
          data-open-label={t.nav.openMenu}
          data-close-label={t.nav.closeMenu}
          data-menu-text={t.nav.menu}
          data-close-text={t.nav.close}
        >
          <span id="menu-label-new" class="text-[1rem] font-mono uppercase">{t.nav.menu}</span>
          <div
            class="flex flex-col justify-center gap-1.75 w-[36px] h-4"
            aria-hidden="true"
          >
            <span
              class="burger-line block w-full h-px bg-[#16191B] transition-all duration-300 ease-out origin-center"
            ></span>
            <span
              class="burger-line block w-full h-px bg-[#16191B] transition-all duration-300 ease-out origin-center"
            ></span>
          </div>
        </button>
      </div>
    </div>

    <!-- Menu panel -->
    <div
      id="menu-panel"
      class="menu-panel bg-black text-bg-light overflow-hidden border-x border-b border-transparent"
      aria-hidden="true"
    >
      <div class="p-5 sm:flex sm:flex-row-reverse sm:justify-between">
        <!-- Navigation links -->
        <nav class="sm:w-1/2">
          <ul class="flex flex-col gap-6">
            {
              items.map((item, index) => (
                <li
                  class="menu-item opacity-0 transition-all duration-300 ease-out text-right"
                  style={`--item-delay: ${index * 0.05}s`}
                >
                  <a
                    href={item.url}
                    class="menu-link nav-scramble inline-block relative text-[2.5rem] leading-none text-black no-underline"
                    target={item.isExternal ? "_blank" : undefined}
                    rel={item.isExternal ? "noopener noreferrer" : undefined}
                    tabindex="-1"
                    data-text={item.label}
                    title={item.label}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>

        <!-- Footer info -->
        <div class="pt-5 mt-5 sm:mt-0 sm:pt-0 border-t border-lines-dark sm:border-0 sm:flex sm:flex-col sm:justify-between">
          <div class="flex flex-col gap-4 text-right sm:text-left">
            <!-- Email -->
            <a
              href={`mailto:${email}`}
              class="menu-item opacity-0 flex justify-end sm:justify-start items-center gap-2.5 transition-all duration-300 ease-out leading-none text-[1rem] font-mono uppercase no-underline hover:opacity-70"
              style="--item-delay: 0.2s"
              tabindex="-1"
              title={email}
            >
              <svg
                class="mt-1"
                width="11"
                height="10"
                viewBox="0 0 11 10"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M7.38206 10L6.60058 9.24904L9.13314 6.39847L0 6.39847V0H1V5.32567H9.13314L6.60058 2.4751L7.38206 1.72414L11 5.86207L7.38206 10Z"
                  fill="#F4F3F3"></path>
              </svg>
              <span class="nav-scramble" data-text={email}>{email}</span>
            </a>

            <!-- Language switch -->
            <a
              href={switchUrl}
              class="menu-item opacity-0 flex justify-end sm:justify-start items-center gap-2.5 transition-all duration-300 ease-out leading-none text-[1rem] font-mono uppercase no-underline hover:opacity-70"
              style="--item-delay: 0.25s"
              hreflang={switchLang}
              tabindex="-1"
              title={t.nav.switchLang}
            >
              <svg
                class="mt-1"
                width="11"
                height="10"
                viewBox="0 0 11 10"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M7.38206 10L6.60058 9.24904L9.13314 6.39847L0 6.39847V0H1V5.32567H9.13314L6.60058 2.4751L7.38206 1.72414L11 5.86207L7.38206 10Z"
                  fill="#F4F3F3"></path>
              </svg>
              <span class="nav-scramble" data-text={t.nav.switchLang}
                >{t.nav.switchLang}</span
              >
            </a>
          </div>
        </div>
      </div>
    </div>

  </div>

</header>

<style is:global>
  /* Desktop header */
  .header-desktop {
    transform: translateY(0);
    transition: transform 0.35s ease-out;
  }

  .header-desktop.relay-active {
    transform: translateY(-100%);
  }

  /* Relay header visibility states */
  .header-new {
    transform: translateY(0);
    transition: transform 0.35s ease-out;
  }

  .header-new.header-hidden {
    transform: translateY(-100%);
  }

  .header-link {
    position: relative;
    display: inline-block;
  }

  .header-link::after {
    content: "";
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: currentColor;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .header-link:hover::after {
    transform: scaleX(1);
  }

  /* Sur lg+, le relay est caché par défaut — visible seulement quand relay-active */
  @media (min-width: 1024px) {
    .header-new:not(.relay-active) {
      transform: translateY(-100%);
    }
  }
</style>

<style>
  /* Burger animation - 2 lines converge to single centered line */
  .header-new.is-open .burger-line:first-child {
    transform: translateY(5px);
    opacity: 0;
  }

  .header-new.is-open .burger-line:last-child {
    transform: translateY(-5px);
  }

  /* Menu panel closed */
  .menu-panel {
    clip-path: inset(0 0 100% 0);
    pointer-events: none;
    visibility: hidden;
    transition:
      clip-path 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      visibility 0s 0.3s;
  }

  /* Menu panel open */
  .header-new.is-open .menu-panel {
    clip-path: inset(0);
    border-color: var(--color-lines-dark);
    pointer-events: auto;
    visibility: visible;
    transition:
      clip-path 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      visibility 0s 0s;
  }

  /* Menu items animation */
  .menu-item {
    transition-delay: var(--item-delay, 0s);
  }

  .header-new.is-open .menu-item {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  function initHeaderNew() {
    const header = document.getElementById("header-new");
    const headerDesktop = document.getElementById("header-desktop");
    const toggle = document.getElementById("menu-toggle-new");
    const label = document.getElementById("menu-label-new") as HTMLElement;
    const panel = document.getElementById("menu-panel");
    const menuLinks = panel?.querySelectorAll("a");

    let isOpen = false;
    let lastScrollY = 0;
    let ticking = false;
    let relayActive = false;
    const RELAY_THRESHOLD = headerDesktop?.offsetHeight ?? 80;

    // Text scramble effect
    let scrambleInterval: number | null = null;
    const scrambleIntervals = new Map<HTMLElement, number>();
    let currentText = toggle?.dataset.menuText || "Menu";

    function shuffleArray<T>(array: T[]): T[] {
      const shuffled = [...array];
      for (let i = shuffled.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
      }
      return shuffled;
    }

    function scrambleText(element: HTMLElement, targetText: string) {
      if (scrambleInterval) {
        clearInterval(scrambleInterval);
      }

      let iteration = 0;
      const originalText = targetText;
      const chars = originalText.split("");

      scrambleInterval = window.setInterval(() => {
        const resolved = chars.slice(0, Math.floor(iteration));
        const remaining = chars.slice(Math.floor(iteration));
        const shuffled = shuffleArray(remaining);

        element.textContent = [...resolved, ...shuffled].join("");

        if (iteration >= originalText.length) {
          if (scrambleInterval) clearInterval(scrambleInterval);
          scrambleInterval = null;
          element.textContent = originalText;
        }

        iteration += 1 / 3;
      }, 30);
    }

    function scrambleNavLink(element: HTMLElement, targetText: string) {
      const existingInterval = scrambleIntervals.get(element);
      if (existingInterval) {
        clearInterval(existingInterval);
      }

      let iteration = 0;
      const originalText = targetText;
      const chars = originalText.split("");

      const intervalId = window.setInterval(() => {
        const resolved = chars.slice(0, Math.floor(iteration));
        const remaining = chars.slice(Math.floor(iteration));
        const shuffled = shuffleArray(remaining);

        element.textContent = [...resolved, ...shuffled].join("");

        if (iteration >= originalText.length) {
          clearInterval(intervalId);
          scrambleIntervals.delete(element);
          element.textContent = originalText;
        }

        iteration += 0.7;
      }, 25);

      scrambleIntervals.set(element, intervalId);
    }

    // Hover effect on menu toggle
    toggle?.addEventListener("mouseenter", () => {
      if (label) {
        scrambleText(label, currentText);
      }
    });

    // Hover effect on nav links
    const navScrambleLinks = document.querySelectorAll(
      "#menu-panel .nav-scramble",
    );
    navScrambleLinks.forEach((link) => {
      link.addEventListener("mouseenter", () => {
        const text =
          (link as HTMLElement).dataset.text || link.textContent || "";
        scrambleNavLink(link as HTMLElement, text);
      });
    });

    // Hover effect on header start project link
    const headerStartProject = document.getElementById("header-start-project");
    const headerStartProjectText = headerStartProject?.querySelector(
      ".nav-scramble-header",
    );
    headerStartProject?.addEventListener("mouseenter", () => {
      if (headerStartProjectText) {
        const text =
          headerStartProject.dataset.text ||
          headerStartProjectText.textContent ||
          "";
        scrambleNavLink(headerStartProjectText as HTMLElement, text);
      }
    });

    function openMenu() {
      isOpen = true;
      header?.classList.add("is-open");
      panel?.setAttribute("aria-hidden", "false");
      toggle?.setAttribute("aria-expanded", "true");
      const closeLabel = toggle?.dataset.closeLabel || "Close menu";
      const closeText = toggle?.dataset.closeText || "Close";
      toggle?.setAttribute("aria-label", closeLabel);
      currentText = closeText;
      if (label) scrambleText(label, closeText);
      menuLinks?.forEach((link) => link.setAttribute("tabindex", "0"));
      document.body.style.overflow = "hidden";
    }

    function closeMenu() {
      isOpen = false;
      header?.classList.remove("is-open");
      panel?.setAttribute("aria-hidden", "true");
      toggle?.setAttribute("aria-expanded", "false");
      const openLabel = toggle?.dataset.openLabel || "Open menu";
      const menuText = toggle?.dataset.menuText || "Menu";
      toggle?.setAttribute("aria-label", openLabel);
      currentText = menuText;
      if (label) scrambleText(label, menuText);
      menuLinks?.forEach((link) => link.setAttribute("tabindex", "-1"));
      document.body.style.overflow = "";
      // Reset scroll state for hide/show detection
      ticking = false;
      lastScrollY = (window as any).lenis?.scroll ?? window.scrollY;
    }

    toggle?.addEventListener("click", () => {
      isOpen ? closeMenu() : openMenu();
    });

    menuLinks?.forEach((link) => {
      link.addEventListener("click", (e) => {
        const href = link.getAttribute("href");
        if (href && href.includes("#")) {
          const hashIndex = href.indexOf("#");
          const hash = href.substring(hashIndex);
          const pathBeforeHash = href.substring(0, hashIndex);
          const currentPath = window.location.pathname;

          // Check if we're on the same page (or navigating to home with hash)
          const isSamePage =
            pathBeforeHash === currentPath ||
            pathBeforeHash === currentPath + "/" ||
            pathBeforeHash + "/" === currentPath;

          if (isSamePage) {
            e.preventDefault();
            closeMenu();

            const targetElement = document.querySelector(hash);
            if (targetElement) {
              // Use Lenis if available, otherwise native scroll
              if ((window as any).lenis) {
                (window as any).lenis.scrollTo(targetElement, { offset: 0 });
              } else {
                targetElement.scrollIntoView({ behavior: "smooth" });
              }
              // Update URL hash without triggering navigation
              history.pushState(null, "", href);
            }
            return;
          }
        }
        closeMenu();
      });
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && isOpen) closeMenu();
    });

    document.addEventListener("click", (e) => {
      if (isOpen && !header?.contains(e.target as Node)) {
        closeMenu();
      }
    });

    function getScrollY(): number {
      return (window as any).lenis?.scroll ?? window.scrollY;
    }

    function updateHeaderVisibility() {
      const currentScrollY = getScrollY();
      const isDesktop = window.innerWidth >= 1024;

      if (isOpen) {
        header?.classList.remove("header-hidden");
        lastScrollY = currentScrollY;
        ticking = false;
        return;
      }

      // Desktop : switch entre header desktop et relay
      if (isDesktop) {
        const shouldRelay = currentScrollY > RELAY_THRESHOLD;
        if (shouldRelay !== relayActive) {
          relayActive = shouldRelay;
          if (shouldRelay) {
            headerDesktop?.classList.add("relay-active");
            header?.classList.add("relay-active");
            header?.classList.remove("header-hidden");
          } else {
            headerDesktop?.classList.remove("relay-active");
            header?.classList.remove("relay-active");
            header?.classList.remove("header-hidden");
          }
          lastScrollY = currentScrollY;
          ticking = false;
          return;
        }
      }

      // Hide/show au scroll (mobile toujours, desktop seulement quand relay actif)
      if (!isDesktop || relayActive) {
        if (currentScrollY < 50) {
          header?.classList.remove("header-hidden");
        } else if (currentScrollY > lastScrollY + 5 && currentScrollY > 100) {
          header?.classList.add("header-hidden");
        } else if (currentScrollY < lastScrollY - 5) {
          header?.classList.remove("header-hidden");
        }
      }

      lastScrollY = currentScrollY;
      ticking = false;
    }

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(updateHeaderVisibility);
        ticking = true;
      }
    }

    // Use Lenis scroll event if available, fallback to native
    if ((window as any).lenis) {
      (window as any).lenis.on("scroll", onScroll);
    } else {
      window.addEventListener("scroll", onScroll, { passive: true });
    }

    // Reset relay state si on passe en dessous du breakpoint lg
    function onResize() {
      if (window.innerWidth < 1024 && relayActive) {
        relayActive = false;
        headerDesktop?.classList.remove("relay-active");
        header?.classList.remove("relay-active");
        header?.classList.remove("header-hidden");
      }
    }
    window.addEventListener("resize", onResize, { passive: true });

    // Cleanup on navigation
    document.addEventListener(
      "astro:before-swap",
      () => {
        if (scrambleInterval) {
          clearInterval(scrambleInterval);
          scrambleInterval = null;
        }
        scrambleIntervals.forEach((id) => clearInterval(id));
        scrambleIntervals.clear();
        if ((window as any).lenis) {
          (window as any).lenis.off("scroll", onScroll);
        } else {
          window.removeEventListener("scroll", onScroll);
        }
        window.removeEventListener("resize", onResize);
        closeMenu();
      },
      { once: true },
    );
  }

  initHeaderNew();
  document.addEventListener("astro:after-swap", initHeaderNew);
</script>
