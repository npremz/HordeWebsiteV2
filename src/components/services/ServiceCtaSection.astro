---
import ContactForm from "../ui/forms/ContactForm";
import type { FormTranslations } from "../ui/forms/ContactForm";
import { formatHeadingHtml } from "../../utils/heading-html";
import type { ServiceData } from "./types";

interface Props {
  service: ServiceData;
  formTranslations: FormTranslations;
}

const { service, formTranslations } = Astro.props;
---

<section id="service-cta" class="mt-16 md:mt-24" data-service-section="cta" aria-labelledby="service-cta-title">
  <h2 id="service-cta-title" class="flex flex-col sm:flex-row sm:justify-between gap-5 text-[1.5rem] sm:text-[2rem] md:text-[2.5rem] leading-tight flex">
    <span set:html={formatHeadingHtml(service.ctaTitle)} class="sm:pr-4" />
    <svg class="self-end sm:self-start mt-2" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
     <rect width="7" height="20" transform="matrix(0.707107 0.707107 0.707107 -0.707107 0 14.1406)" fill="#16191B"/>
    </svg>
  </h2>
  <div class="mt-5 sm:mt-10">
    <div class="space-y-8 sm:space-y-5 md:max-w-[650px]">
      {service.ctaParagraphs.map((paragraph) => {
        const emailRegex = /(hello@hordeagence\.com)/;
        const parts = paragraph.split(emailRegex);
        return (
          <p class="text-[1.125rem] max-w-[900px]">
            {parts.map((part) =>
              part === 'hello@hordeagence.com'
                ? <a class="cta-email-link" href="mailto:hello@hordeagence.com">{part}</a>
                : part
            )}
          </p>
        );
      })}
    </div>

    <div id="contact-form" class="mt-16">
      <ContactForm
        client:load
        translations={formTranslations}
        variant="light"
        hideNeedField={true}
        source={{
          type: 'service-page',
          pagePath: service.seoUrl,
          serviceSlug: service.slug,
        }}
      />
    </div>
  </div>
</section>

<style>
  .cta-email-link {
    position: relative;
    display: inline-block;
    border-bottom: 1px solid rgb(0 0 0 / 0.3);
  }

  .cta-email-link::after {
    content: "";
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: currentColor;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .cta-email-link:hover::after {
    transform: scaleX(1);
  }
</style>
