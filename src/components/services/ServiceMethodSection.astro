---
import ServiceSectionHeading from "./ServiceSectionHeading.astro";
import type { ServiceData } from "./types";

interface Props {
  service: ServiceData;
}

const { service } = Astro.props;
---

<section id="service-method" class="mt-16 lg:mt-24" data-service-section="method" aria-labelledby="service-method-title">
  <ServiceSectionHeading
    id="service-method-title"
    left={service.methodTitleLeft}
    right={service.methodTitleRight}
  />
  <div class="py-16 lg:pt-32 lg:pb-50 border-y border-lines space-y-16 sm:space-y-0 sm:grid sm:grid-cols-2 lg:grid-cols-4 sm:gap-x-5 lg:gap-y-16">
    {service.methodSteps.map((step, index) => (
      <article class:list={[
        "flex flex-col",
        {"sm:mt-50": (index % 2 == 1)}
      ]}>
        <span class="font-mono text-[1rem] leading-none whitespace-nowrap">
          / {String(index + 1).padStart(3, "0")}
        </span>
        <div class="w-full mt-4 bg-white p-6">
          <div class="flex justify-between items-end">
            <h3 class="text-[1.5rem] sm:text-[2rem] leading-[1.2]">{step.title}</h3>
          </div>
          <p class="mt-30">{step.body}</p>
        </div>
      </article>
    ))}
  </div>
</section>
