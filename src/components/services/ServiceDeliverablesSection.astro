---
import { formatHeadingHtml } from "../../utils/heading-html";
import type { ServiceData } from "./types";
import { DEFAULT_LOCALE, type Locale, useTranslations } from "../../i18n";

interface Props {
  service: ServiceData;
  lang?: Locale;
}

const { service, lang = DEFAULT_LOCALE } = Astro.props;
const t = useTranslations(lang);
---

<section
  id="service-deliverables"
  class="mt-20 lg:mt-24"
  data-service-section="deliverables"
  aria-labelledby="service-deliverables-title"
>
  <h2
    id="service-deliverables-title"
    class="text-[1.5rem] sm:text-[2rem] md:text-[2.5rem] leading-none"
    set:html={formatHeadingHtml(service.deliverablesTitle)}
  />
  <p class="mt-16 section-label lg:max-w-1/2 lg:self-end lg:w-full">
    <span class="block lg:translate-0 lg:pl-16">{t.homepage.demarche.expectationLine1}<br/> {t.homepage.demarche.expectationLine2}</span>
    <span class="block text-right">{t.homepage.demarche.expectationLine3}<br/> {t.homepage.demarche.expectationLine4}</span>
  </p>
  <div class="mt-16">
    <ul class="space-y-2.5">
      {service.deliverables.map((item, index) => (
        <li class="flex items-center gap-5">
          <span class="flex  w-full leading-normal text-[1.125rem] md:text-[1.5rem] lg:text-[2.5rem] p-2.5 sm:py-8 md:px-6 md:py-[38px] lg:py-[38px] lg:px-9 sm:w-fit items-center bg-white sm:text-left">
            <span class="pr-4 block">{String(index + 1).padStart(1, "0")}/</span> {item}
          </span>
        </li>
      ))}
    </ul>
  </div>
</section>
