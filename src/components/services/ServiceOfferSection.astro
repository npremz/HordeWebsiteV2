---
import { formatHeadingHtml } from "../../utils/heading-html";
import type { ServiceData } from "./types";

interface Props {
  service: ServiceData;
}

const { service } = Astro.props;
---

<section id="service-offer" class="mt-10 sm:mt-16 md:mt-24" data-service-section="offer" aria-labelledby="service-offer-title">
  <h2
    id="service-offer-title"
    class="text-[1.5rem] sm:text-[2rem] md:text-[2.5rem] leading-none pb-16 sm:pb-24 lg:pb-32"
    set:html={formatHeadingHtml(service.offerTitle)}
  />
  <div class="space-y-16 md:space-y-0 md:grid md:grid-cols-2 lg:grid-cols-3 md:gap-20 lg:gap-x-32">
    {service.offerItems.map((item, index) => (
      <article>
        <span class="font-mono text-[1rem] block">
          {String(index + 1).padStart(2, "0")}
        </span>
        <h3 class="text-[1.375rem] sm:text-[1.5rem] leading-none mt-4 sm:mt-2.5">{item.title}</h3>
        <p class="mt-8 text-[1.125rem]">{item.body}</p>
      </article>
    ))}
  </div>
</section>
