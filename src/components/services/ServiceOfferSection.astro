---
import ServiceSectionHeading from "./ServiceSectionHeading.astro";
import type { ServiceData } from "./types";

interface Props {
  service: ServiceData;
}

const { service } = Astro.props;
---

<section id="service-offer" class="mt-10 sm:mt-16 md:mt-24" data-service-section="offer" aria-labelledby="service-offer-title">
  <ServiceSectionHeading
    id="service-offer-title"
    left={service.offerTitleLeft}
    right={service.offerTitleRight}
  />
  <div class="py-16 sm:pb-25 md:pt-32 lg:pt-24 md:pb-50 border-y border-lines space-y-16 md:space-y-0 md:grid md:grid-cols-2 md:gap-x-10 lg:gap-x-25 md:gap-y-32">
    {service.offerItems.map((item, index) => (
      <article class="flex">
        <div class="w-full">
          <div class="flex justify-between items-end">
            <h3 class="text-[1.5rem] leading-none">{item.title}</h3>
            <span class="font-mono text-[1rem] whitespace-nowrap">
              / {String(index + 1).padStart(3, "0")}
            </span>
          </div>
          <p class="mt-8">{item.body}</p>
        </div>
      </article>
    ))}
  </div>
</section>
