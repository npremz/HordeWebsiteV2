---
import { formatHeadingHtml } from "../../utils/heading-html";
import type { ServiceData } from "./types";
import ServiceSection from "./ServiceSection.astro";

interface Props {
  service: ServiceData;
}

const { service } = Astro.props;

const sectionClass = "mt-10 sm:mt-16 md:mt-24";
const titleClass = "text-[1.5rem] leading-none pb-16 sm:text-[2rem] sm:pb-24 md:text-[2.5rem] lg:pb-32";
const gridClass = "space-y-[60px] md:grid md:grid-cols-2 md:space-y-0 md:gap-20 lg:grid-cols-3 lg:gap-32";
---

<ServiceSection
  id="service-offer"
  sectionKey="offer"
  titleId="service-offer-title"
  class={sectionClass}
>
  <h2
    id="service-offer-title"
    class={titleClass}
    set:html={formatHeadingHtml(service.offerTitle)}
  />
  <div class={gridClass}>
    {service.offerItems.map((item, index) => (
      <article>
        <span class="font-mono text-[1rem] block">
          {String(index + 1).padStart(2, "0")}
        </span>
        <h3 class="text-[1.375rem] sm:text-[1.5rem] leading-none mt-4 sm:mt-2.5">{item.title}</h3>
        <p class="mt-8 text-[1.125rem]">{item.body}</p>
      </article>
    ))}
  </div>
</ServiceSection>
