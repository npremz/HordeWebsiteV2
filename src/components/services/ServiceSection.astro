---
interface Props {
  id: string;
  titleId: string;
  sectionKey: string;
  class?: string;
}

const {
  id,
  titleId,
  sectionKey,
  class: className = "",
} = Astro.props as Props;
---

<section
  id={id}
  data-service-section={sectionKey}
  aria-labelledby={titleId}
  class={className}
>
  <slot />
</section>
