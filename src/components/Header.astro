                  <path d="M112.206 0.000537426V3.00047H91.8051V11.9996H112.206V3.00047L115.12 2.99977V14.9995H88.8905V0.000537426H112.206Z" fill="currentColor"/>
                </g>
                <g class="logo-full__letter" style="--i:4">
