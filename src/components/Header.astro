---
import {
  DEFAULT_LOCALE,
  type Locale,
  useTranslations,
  getLocalizedPath,
  getPathWithoutLocale,
} from '../i18n';
import { getNavigation } from '../lib/site-data';

interface Props {
  lang?: Locale;
  alternateUrl?: string;
  theme?: 'light' | 'dark';
}

const { lang = DEFAULT_LOCALE, alternateUrl, theme = 'light' } = Astro.props;
const t = useTranslations(lang);
const isDark = theme === 'dark';

const currentPath = getPathWithoutLocale(Astro.url.pathname);
const switchLang = lang === 'fr' ? 'en' : 'fr';
const switchUrl = alternateUrl || getLocalizedPath(currentPath, switchLang);
const startProjectUrl = getLocalizedPath('/contact', lang);

const navigation = await getNavigation(lang);
const {
  logo = '/images/logo.svg',
  logoAlt = 'Logo',
  items = [],
  ctaButton,
} = navigation;

const emailUrl = ctaButton?.url || 'mailto:hello@hordeagence.com';
const emailLabel = ctaButton?.label || 'hello@hordeagence.com';
const textClasses = isDark ? 'text-bg-light' : 'text-black';
const logoClasses = isDark ? 'invert' : '';
const mobilePanelClasses = isDark
  ? 'border-white/10 bg-black/88 text-bg-light shadow-[0_18px_60px_rgba(0,0,0,0.35)]'
  : 'border-black/10 bg-bg-light/92 text-black shadow-[0_18px_60px_rgba(22,25,27,0.14)]';
const desktopLinkClasses = isDark
  ? 'text-bg-light/85 hover:text-bg-light'
  : 'text-black/70 hover:text-black';
const secondaryActionClasses = isDark
  ? 'border-white/10 bg-white/4 text-bg-light hover:bg-white/8'
  : 'border-black/10 bg-white/60 text-black hover:bg-white/85';
---

<header class:list={['fixed inset-x-0 top-0 z-[9999] pointer-events-none', textClasses]} data-theme={theme}>
  <div class="px-(--gutter) pt-(--gutter) lg:hidden">
    <div class="flex items-center justify-between gap-4">
      <a
        href={`/${lang}`}
        class="pointer-events-auto inline-flex items-center"
        title={logoAlt}
        aria-label={logoAlt}
      >
        <img
          src={logo}
          alt={logoAlt}
          class:list={['block h-auto w-auto max-w-full', logoClasses]}
          width="112"
          height="40"
          decoding="async"
        />
      </a>

      <button
        type="button"
        class="site-header__menu-toggle pointer-events-auto inline-flex items-center justify-center bg-transparent p-0 text-current"
        data-header-toggle
        data-open-label={t.nav.openMenu}
        data-close-label={t.nav.closeMenu}
        data-menu-open="false"
        aria-expanded="false"
        aria-controls="site-header-mobile-panel"
        aria-label={t.nav.openMenu}
      >
        <span class="relative flex h-4 w-8 flex-col justify-center" aria-hidden="true">
          <span class="site-header__menu-toggle-line absolute left-0 block h-px w-full bg-current"></span>
          <span class="site-header__menu-toggle-line absolute left-0 block h-px w-full bg-current"></span>
        </span>
      </button>
    </div>

    <div
      id="site-header-mobile-panel"
      class:list={[
        'pointer-events-auto mt-4 overflow-hidden rounded-[1.75rem] border p-5 backdrop-blur-xl sm:p-6',
        mobilePanelClasses,
      ]}
      data-header-panel
      hidden
    >
      <nav aria-label="Navigation principale">
        <ul class="m-0 flex list-none flex-col gap-2 p-0">
          {items.map((item) => (
            <li>
              <a
                href={item.url}
                class="inline-flex min-h-11 w-full items-center rounded-2xl border border-transparent px-4 py-3 text-[1.125rem] leading-none tracking-[-0.02em] transition-colors duration-200 hover:border-current/10 hover:bg-black/4 sm:text-[1.25rem]"
                target={item.isExternal ? '_blank' : undefined}
                rel={item.isExternal ? 'noopener noreferrer' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="mt-5 flex flex-col gap-2 border-t border-current/10 pt-5">
        <a
          href={startProjectUrl}
          class="inline-flex min-h-11 items-center justify-center rounded-full bg-black px-5 py-3 text-center text-[0.95rem] font-medium leading-none text-bg-light transition-opacity duration-200 hover:opacity-90"
        >
          {t.nav.startProject}
        </a>
        <a
          href={emailUrl}
          class:list={[
            'inline-flex min-h-11 items-center justify-center rounded-full border px-5 py-3 text-center text-[0.95rem] leading-none transition-colors duration-200',
            secondaryActionClasses,
          ]}
        >
          {emailLabel}
        </a>
        <a
          href={switchUrl}
          hreflang={switchLang}
          class:list={[
            'inline-flex min-h-11 items-center justify-center rounded-full border px-5 py-3 text-center text-[0.95rem] leading-none transition-colors duration-200',
            secondaryActionClasses,
          ]}
        >
          {t.nav.switchLang}
        </a>
      </div>
    </div>
  </div>

  <div class="hidden grid-cols-[1fr_auto_1fr] items-start px-(--gutter) pt-(--gutter) lg:grid">
    <div class="justify-self-start">
      <a
        href={startProjectUrl}
        class:list={[
          'pointer-events-auto inline-flex min-h-11 items-center rounded-full border px-5 py-3 text-[0.95rem] leading-none transition-colors duration-200',
          secondaryActionClasses,
        ]}
      >
        {t.nav.startProject}
      </a>
    </div>

    <div class="justify-self-center">
      <a
        href={`/${lang}`}
        class="pointer-events-auto inline-flex items-center"
        title={logoAlt}
        aria-label={logoAlt}
      >
        <img
          src="/images/logo_full.svg"
          alt={logoAlt}
          class:list={['block h-auto w-auto max-w-full', logoClasses]}
          width="320"
          height="15"
          decoding="async"
        />
      </a>
    </div>

    <nav class="pointer-events-auto justify-self-end" aria-label="Navigation principale">
      <ul class="m-0 flex list-none flex-col items-end gap-2 p-0">
        {items.map((item) => (
          <li>
            <a
              href={item.url}
              class:list={[
                'inline-flex items-center rounded-full px-3 py-1 text-right text-[1.125rem] leading-none tracking-[-0.02em] transition-colors duration-200',
                desktopLinkClasses,
              ]}
              target={item.isExternal ? '_blank' : undefined}
              rel={item.isExternal ? 'noopener noreferrer' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style is:global>
  .site-header__menu-toggle-line {
    top: 50%;
    transform-origin: center;
    transition: transform 180ms ease-out;
  }

  .site-header__menu-toggle-line:first-child {
    transform: translateY(-0.1875rem);
  }

  .site-header__menu-toggle-line:last-child {
    transform: translateY(0.1875rem);
  }

  .site-header__menu-toggle[data-menu-open='true'] .site-header__menu-toggle-line:first-child {
    transform: translateY(0);
  }

  .site-header__menu-toggle[data-menu-open='true'] .site-header__menu-toggle-line:last-child {
    transform: translateY(0);
  }
</style>

<script>
  function initHeader() {
    const headers = document.querySelectorAll('.site-header');

    headers.forEach((header) => {
      const toggle = header.querySelector('[data-header-toggle]');
      const panel = header.querySelector('[data-header-panel]');

      if (!(toggle instanceof HTMLButtonElement) || !(panel instanceof HTMLElement)) {
        return;
      }

      if (toggle.dataset.headerBound === 'true') {
        return;
      }

      const closeMenu = () => {
        toggle.dataset.menuOpen = 'false';
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', toggle.dataset.openLabel || 'Open menu');
        panel.hidden = true;
      };

      const openMenu = () => {
        toggle.dataset.menuOpen = 'true';
        toggle.setAttribute('aria-expanded', 'true');
        toggle.setAttribute('aria-label', toggle.dataset.closeLabel || 'Close menu');
        panel.hidden = false;
      };

      toggle.addEventListener('click', () => {
        const isOpen = toggle.getAttribute('aria-expanded') === 'true';
        if (isOpen) {
          closeMenu();
        } else {
          openMenu();
        }
      });

      panel.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          closeMenu();
        });
      });

      toggle.dataset.headerBound = 'true';
    });
  }

  initHeader();
  document.addEventListener('astro:after-swap', initHeader);
</script>
