                </g>
                <g class="logo-full__letter" style="--i:2">
                  <path d="M62.175 6.0004H82.5762V8.99963H85.4902V14.9988H82.5756L82.5762 8.99963H62.175V14.9988H59.2603V2.99977H62.175V6.0004Z" fill="currentColor"/>
