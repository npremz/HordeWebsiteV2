---
import {
  DEFAULT_LOCALE,
  type Locale,
  useTranslations,
  getLocalizedPath,
  getPathWithoutLocale,
} from '../i18n';
import { getNavigation } from '../lib/site-data';

interface Props {
  lang?: Locale;
  alternateUrl?: string;
  theme?: 'light' | 'dark';
}

const { lang = DEFAULT_LOCALE, alternateUrl, theme = 'light' } = Astro.props;
const t = useTranslations(lang);
const isDark = theme === 'dark';

const currentPath = getPathWithoutLocale(Astro.url.pathname);
const switchLang = lang === 'fr' ? 'en' : 'fr';
const switchUrl = alternateUrl || getLocalizedPath(currentPath, switchLang);
const startProjectUrl = getLocalizedPath('/contact', lang);

const navigation = await getNavigation(lang);
const {
  logo = '/images/logo.svg',
  logoAlt = 'Logo',
  items = [],
  ctaButton,
} = navigation;

const emailUrl = ctaButton?.url || 'mailto:hello@hordeagence.com';
const emailLabel = ctaButton?.label || 'hello@hordeagence.com';
const textClasses = isDark ? 'text-bg-light' : 'text-black';
const logoClasses = isDark ? 'invert' : '';
const desktopLinkClasses = isDark
  ? 'text-bg-light/85 hover:text-bg-light'
  : 'text-black/70 hover:text-black';

---

<header class:list={['site-header fixed md:absolute inset-x-0 top-0 z-[9999] pointer-events-none', textClasses]} data-theme={theme}>
  <div class="relative z-[3] md:hidden">
    <div class="site-header__mobile-fixed px-(--gutter) py-(--gutter)" data-mobile-fixed>
      <div class="relative z-[5] flex items-center justify-between gap-4" data-mobile-row>
        <a
          href={`/${lang}`}
          class="pointer-events-auto inline-flex items-center"
          title={logoAlt}
          aria-label={logoAlt}
        >
          <img
            src={logo}
            alt={logoAlt}
            class:list={['site-header__mobile-logo block h-[13px] w-auto max-w-full', logoClasses]}
            width="112"
            height="13"
            decoding="async"
          />
        </a>

        <button
          type="button"
          class="site-header__menu-toggle pointer-events-auto cursor-pointer inline-flex gap-2.5 text-[1.125rem] items-center justify-center bg-transparent p-0 text-current"
          data-header-toggle
          data-open-label={t.nav.openMenu}
          data-close-label={t.nav.closeMenu}
          data-menu-text={t.nav.menu}
          data-close-text={t.nav.close}
          data-menu-open="false"
          aria-expanded="false"
          aria-controls="site-header-mobile-panel"
          aria-label={t.nav.openMenu}
        >
          <span data-header-toggle-label>{t.nav.menu}</span>
          <span class="relative flex h-4 w-8 flex-col justify-center" aria-hidden="true">
            <span class="site-header__menu-toggle-line absolute left-0 block h-px w-full bg-current"></span>
            <span class="site-header__menu-toggle-line absolute left-0 block h-px w-full bg-current"></span>
          </span>
        </button>
      </div>

      <div
        class="relative z-[5] mt-(--gutter) h-px w-[calc(100vw-(var(--gutter)*2))] bg-lines"
        data-header-divider
        hidden
      ></div>
    </div>

    <div
      id="site-header-mobile-panel"
      class:list={[
        'site-header__mobile-panel pointer-events-auto fixed inset-0 z-[2] flex min-h-[100dvh] flex-col mx-(--gutter) pt-[calc(var(--gutter)+3rem)] pb-(--gutter) text-black',
      ]}
      data-header-panel
      hidden
    >
      <div class="flex flex-1 items-center">
        <nav aria-label="Navigation principale" class="w-full">
          <ul class="m-0 flex list-none flex-col items-end gap-5 p-0">
            {items.map((item) => (
              <li>
                <a
                  href={item.url}
                  class="inline-flex text-right items-center text-[1.375rem] leading-none tracking-[-0.02em] transition-colors duration-200 hover:border-current/10 hover:bg-black/4 sm:text-[1.9rem]"
                  target={item.isExternal ? '_blank' : undefined}
                  rel={item.isExternal ? 'noopener noreferrer' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

      <div class="flex items-end justify-between">
        <div class="flex flex-col items-start">
          <a
            href={startProjectUrl}
            class="site-header__mobile-footer-link site-header__mobile-footer-link--arrow inline-flex min-h-11 items-center text-[18px] leading-none transition-opacity duration-200 hover:opacity-90"
          >
            {t.nav.startProject}
          </a>
          <a
            href={emailUrl}
            class="site-header__mobile-footer-link site-header__mobile-footer-link--arrow inline-flex min-h-11 items-center text-[18px] leading-none transition-opacity duration-200 hover:opacity-90"
          >
            {emailLabel}
          </a>
        </div>
        <a
          href={switchUrl}
          hreflang={switchLang}
          class="site-header__mobile-footer-link inline-flex min-h-11 items-center text-[18px] leading-none transition-opacity duration-200 hover:opacity-90"
        >
          {t.nav.switchLang}
        </a>
      </div>
    </div>

    <div class="site-header__mobile-reveal" data-header-reveal aria-hidden="true" hidden></div>
  </div>

  <div class="hidden md:block">
    <div class="site-header__desktop-fixed fixed inset-x-0 top-0 z-[6]" data-desktop-fixed>
      <div data-desktop-row>
        <div class="flex items-center justify-between px-8 py-5">
          <a href={`/${lang}`} class="inline-flex items-center" title={logoAlt} aria-label={logoAlt}>
            <img
              src="/images/logo_full.svg"
              alt={logoAlt}
              class="block h-[13px] w-auto max-w-full"
              width="320"
              height="13"
              decoding="async"
            />
          </a>

          <button
            type="button"
            class="site-header__desktop-toggle inline-flex cursor-pointer gap-2.5 items-center justify-center bg-transparent p-0 text-black text-[18px] leading-none"
            data-desktop-toggle
            data-menu-open="false"
            aria-expanded="false"
            aria-controls="site-header-desktop-curtain"
            aria-label={t.nav.openMenu}
          >
            <span data-desktop-toggle-label>{t.nav.menu}</span>
            <span class="relative flex h-4 w-8 flex-col justify-center" aria-hidden="true">
              <span class="site-header__desktop-toggle-line absolute left-0 block h-px w-full bg-current"></span>
              <span class="site-header__desktop-toggle-line absolute left-0 block h-px w-full bg-current"></span>
            </span>
          </button>
        </div>
      </div>

      <div
        id="site-header-desktop-curtain"
        class="site-header__desktop-curtain bg-[#FFFFFF] text-black"
        data-desktop-curtain
        hidden
      >
        <div class="flex flex-col px-6 py-5 gap-[20px]">
          <nav aria-label="Navigation desktop curtain">
            <ul class="m-0 flex list-none items-center justify-between gap-1 p-0 text-[18px] leading-none -mx-1">
              {items.map((item) => (
                <li>
                  <a
                    href={item.url}
                    class="nav-link-hover relative inline-flex items-center whitespace-nowrap px-1 py-1"
                    target={item.isExternal ? '_blank' : undefined}
                    rel={item.isExternal ? 'noopener noreferrer' : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>

          <div class="h-px w-full bg-black"></div>

          <div class="flex flex-col items-end gap-[20px] text-[18px] leading-none">
            <a
              href={switchUrl}
              hreflang={switchLang}
              class="nav-link-hover site-header__mobile-footer-link site-header__mobile-footer-link--arrow relative inline-flex items-center pr-2 py-1"
            >
              {t.nav.switchLang}
            </a>
            <a
              href={startProjectUrl}
              class="nav-link-hover site-header__mobile-footer-link site-header__mobile-footer-link--arrow relative inline-flex items-center pr-2 py-1"
            >
              {t.nav.startProject}
            </a>
            <a
              href={emailUrl}
              class="nav-link-hover site-header__mobile-footer-link site-header__mobile-footer-link--arrow relative inline-flex items-center pr-2 py-1"
            >
              {emailLabel}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<style is:global>
  .site-header__desktop-fixed {
    pointer-events: auto;
  }

  .site-header__desktop-toggle-line {
    top: 50%;
    transform-origin: center;
    transition: transform 180ms ease-out;
  }

  .site-header__desktop-toggle-line:first-child {
    transform: translateY(-0.2375rem);
  }

  .site-header__desktop-toggle-line:last-child {
    transform: translateY(0.2375rem);
  }

  .site-header__desktop-toggle[data-menu-open='true'] .site-header__desktop-toggle-line:first-child {
    transform: translateY(0);
  }

  .site-header__desktop-toggle[data-menu-open='true'] .site-header__desktop-toggle-line:last-child {
    transform: translateY(0);
  }

  .site-header__desktop-curtain {
    position: absolute;
    right: 2rem;
    top: var(--desktop-header-height, 86px);
    width: 511px;
    max-width: calc(100vw - 4rem);
    opacity: 0;
    transform: translateY(-8px);
    transition: opacity 220ms ease, transform 220ms ease;
  }

  .site-header__desktop-curtain.is-open {
    opacity: 1;
    transform: translateY(0);
  }

  .site-header__mobile-fixed {
    position: relative;
    z-index: 5;
    opacity: 1;
    transform: translateY(0);
    transition: opacity 220ms ease, transform 220ms ease, background-color 220ms ease, color 220ms ease;
    pointer-events: none;
  }

  .site-header__mobile-fixed.is-solid {
    background: #fff;
    color: #000;
  }

  .site-header__mobile-fixed.is-hidden {
    opacity: 0;
    transform: translateY(calc(-100% - var(--gutter)));
  }

  .site-header__mobile-fixed [data-mobile-row],
  .site-header__mobile-fixed [data-header-divider] {
    pointer-events: none;
  }

  .site-header__mobile-fixed:not(.is-hidden) [data-mobile-row],
  .site-header__mobile-fixed:not(.is-hidden) [data-header-divider] {
    pointer-events: auto;
  }

  .site-header__mobile-fixed.is-solid .site-header__mobile-logo {
    filter: none;
  }

  .site-header__mobile-reveal {
    position: fixed;
    inset-inline: 0;
    top: 0;
    height: 100vh;
    background: #fff;
    transform: translateY(-100%);
    transition: transform 360ms cubic-bezier(0.2, 0.8, 0.2, 1);
    z-index: 1;
    pointer-events: none;
  }

  .site-header__mobile-reveal.is-open {
    transform: translateY(0);
  }

  .site-header__mobile-panel {
    opacity: 0;
    transform: translateY(-16px);
    transition: opacity 220ms ease, transform 280ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .site-header__mobile-panel.is-open {
    opacity: 1;
    transform: translateY(0);
  }

  .site-header__menu-toggle-line {
    top: 50%;
    transform-origin: center;
    transition: transform 180ms ease-out;
  }

  .site-header__menu-toggle-line:first-child {
    transform: translateY(-0.2375rem);
  }

  .site-header__menu-toggle-line:last-child {
    transform: translateY(0.2375rem);
  }

  .site-header__menu-toggle[data-menu-open='true'] .site-header__menu-toggle-line:first-child {
    transform: translateY(0);
  }

  .site-header__menu-toggle[data-menu-open='true'] .site-header__menu-toggle-line:last-child {
    transform: translateY(0);
  }

  .site-header__mobile-footer-link {
    position: relative;
  }

  .site-header__mobile-footer-link--arrow {
    padding-left: 1.25rem;
  }

  .site-header__mobile-footer-link--arrow::before {
    content: "\2192";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-52%) translateX(0);
    transition: transform 180ms ease-out;
  }

  .site-header__mobile-footer-link--arrow:hover::before {
    transform: translateY(-52%) translateX(2px);
  }

  .nav-link-hover {
    isolation: isolate;
    transition: color 0.3s ease-out;
  }

  .nav-link-hover::after {
    content: "";
    position: absolute;
    inset: 0;
    background-color: #000;
    z-index: -1;
    transform: scaleY(0);
    transform-origin: top center;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  @media (hover: hover) {
    .nav-link-hover:hover {
      color: #fff;
    }
    .nav-link-hover:hover::after {
      transform: scaleY(1);
    }
  }
</style>

<script>
  function initHeader() {
    const headers = document.querySelectorAll('.site-header');

    headers.forEach((header) => {
      const toggle = header.querySelector('[data-header-toggle]');
      const panel = header.querySelector('[data-header-panel]');
      const reveal = header.querySelector('[data-header-reveal]');
      const label = header.querySelector('[data-header-toggle-label]');
      const divider = header.querySelector('[data-header-divider]');
      const mobileFixed = header.querySelector('[data-mobile-fixed]');
      const desktopFixed = header.querySelector('[data-desktop-fixed]');
      const desktopRow = header.querySelector('[data-desktop-row]');
      const desktopToggle = header.querySelector('[data-desktop-toggle]');
      const desktopCurtain = header.querySelector('[data-desktop-curtain]');

      if (
        !(toggle instanceof HTMLButtonElement) ||
        !(panel instanceof HTMLElement) ||
        !(reveal instanceof HTMLElement) ||
        !(label instanceof HTMLElement) ||
        !(divider instanceof HTMLElement) ||
        !(mobileFixed instanceof HTMLElement)
      ) {
        return;
      }

      if (toggle.dataset.headerBound === 'true') {
        return;
      }

      let closeTimeout: number | undefined;
      let mobileLastScrollY = window.scrollY;
      let isMobileHiddenByScroll = false;
      const MOBILE_SCROLL_DELTA_THRESHOLD = 8;
      const MOBILE_HIDE_OFFSET = 110;
      const MOBILE_SOLID_OFFSET = 6;
      const MOBILE_BREAKPOINT = 1024;

      const isMobileViewport = () => window.innerWidth < MOBILE_BREAKPOINT;

      const applyMobileHeaderState = () => {
        if (!isMobileViewport()) {
          mobileFixed.classList.remove('is-hidden');
          mobileFixed.classList.remove('is-solid');
          return;
        }

        const currentScrollY = window.scrollY;
        const isAtTop = currentScrollY <= MOBILE_SOLID_OFFSET;
        const isMenuOpen = toggle.getAttribute('aria-expanded') === 'true';
        const shouldHide = !isAtTop && isMobileHiddenByScroll && !isMenuOpen;

        mobileFixed.classList.toggle('is-hidden', shouldHide);
        mobileFixed.classList.toggle('is-solid', !isAtTop);
      };

      const handleMobileScroll = () => {
        if (!isMobileViewport()) return;

        const currentScrollY = window.scrollY;
        const delta = currentScrollY - mobileLastScrollY;

        if (currentScrollY <= MOBILE_SOLID_OFFSET) {
          isMobileHiddenByScroll = false;
          mobileLastScrollY = currentScrollY;
          applyMobileHeaderState();
          return;
        }

        if (Math.abs(delta) < MOBILE_SCROLL_DELTA_THRESHOLD) return;

        if (delta > 0 && currentScrollY > MOBILE_HIDE_OFFSET) {
          isMobileHiddenByScroll = true;
        } else if (delta < 0) {
          isMobileHiddenByScroll = false;
        }

        mobileLastScrollY = currentScrollY;
        applyMobileHeaderState();
      };

      const handleMobileResize = () => {
        if (!isMobileViewport()) {
          isMobileHiddenByScroll = false;
        }
        mobileLastScrollY = window.scrollY;
        applyMobileHeaderState();
      };

      const closeMenu = (immediate = false) => {
        toggle.dataset.menuOpen = 'false';
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', toggle.dataset.openLabel || 'Open menu');
        label.textContent = toggle.dataset.menuText || 'Menu';
        panel.classList.remove('is-open');
        reveal.classList.remove('is-open');
        divider.hidden = true;
        window.clearTimeout(closeTimeout);

        if (immediate) {
          panel.hidden = true;
          reveal.hidden = true;
          applyMobileHeaderState();
          return;
        }

        closeTimeout = window.setTimeout(() => {
          if (toggle.getAttribute('aria-expanded') === 'false') {
            panel.hidden = true;
            reveal.hidden = true;
          }
        }, 360);
        applyMobileHeaderState();
      };

      const openMenu = () => {
        toggle.dataset.menuOpen = 'true';
        toggle.setAttribute('aria-expanded', 'true');
        toggle.setAttribute('aria-label', toggle.dataset.closeLabel || 'Close menu');
        label.textContent = toggle.dataset.closeText || 'Close';
        window.clearTimeout(closeTimeout);
        panel.hidden = false;
        reveal.hidden = false;
        divider.hidden = false;
        isMobileHiddenByScroll = false;
        applyMobileHeaderState();

        requestAnimationFrame(() => {
          panel.classList.add('is-open');
          reveal.classList.add('is-open');
        });
      };

      toggle.addEventListener('click', () => {
        const isOpen = toggle.getAttribute('aria-expanded') === 'true';
        if (isOpen) {
          closeMenu();
        } else {
          openMenu();
        }
      });

      panel.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          closeMenu();
        });
      });

      closeMenu(true);
      applyMobileHeaderState();
      window.addEventListener('scroll', handleMobileScroll, { passive: true });
      window.addEventListener('resize', handleMobileResize, { passive: true });
      toggle.dataset.headerBound = 'true';

      if (
        desktopFixed instanceof HTMLElement &&
        desktopRow instanceof HTMLElement &&
        desktopToggle instanceof HTMLButtonElement &&
        desktopCurtain instanceof HTMLElement &&
        desktopFixed.dataset.desktopBound !== 'true'
      ) {
        const rowHeight = desktopRow.getBoundingClientRect().height;
        if (rowHeight > 0) {
          desktopFixed.style.setProperty('--desktop-header-height', `${rowHeight}px`);
        }

        let desktopCloseTimeout: number | undefined;

        const setToggleState = (open: boolean) => {
          const text = open ? (desktopToggle.dataset.closeText || 'Fermer') : (desktopToggle.dataset.menuText || 'Menu');
          desktopToggle.dataset.menuOpen = open ? 'true' : 'false';
          desktopToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
          const fixedLabel = header.querySelector('[data-desktop-toggle-label]');
          if (fixedLabel) fixedLabel.textContent = text;
        };

        const closeDesktopMenu = (immediate = false) => {
          setToggleState(false);
          desktopCurtain.classList.remove('is-open');
          window.clearTimeout(desktopCloseTimeout);

          if (immediate) {
            desktopCurtain.hidden = true;
            return;
          }

          desktopCloseTimeout = window.setTimeout(() => {
            if (desktopToggle.getAttribute('aria-expanded') === 'false') {
              desktopCurtain.hidden = true;
            }
          }, 220);
        };

        const openDesktopMenu = () => {
          setToggleState(true);
          window.clearTimeout(desktopCloseTimeout);
          desktopCurtain.hidden = false;

          requestAnimationFrame(() => {
            desktopCurtain.classList.add('is-open');
          });
        };

        desktopToggle.addEventListener('click', () => {
          const isOpen = desktopToggle.getAttribute('aria-expanded') === 'true';
          if (isOpen) {
            closeDesktopMenu();
          } else {
            openDesktopMenu();
          }
        });

        desktopCurtain.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => {
            closeDesktopMenu();
          });
        });

        closeDesktopMenu(true);

        desktopFixed.dataset.desktopBound = 'true';
      }
    });
  }

  initHeader();
  document.addEventListener('astro:after-swap', initHeader);
</script>
