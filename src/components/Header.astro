                  <path d="M144.751 3.00047L121.435 2.99977V0.000537426H144.751V3.00047Z" fill="currentColor"/>
                </g>
                <g class="logo-full__letter" style="--i:5">
                  <path d="M157.38 14.9986H154.465V9.19893H157.38V14.9986Z" fill="currentColor"/>
