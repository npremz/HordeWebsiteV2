---
import {
  DEFAULT_LOCALE,
  type Locale,
  useTranslations,
  getLocalizedPath,
  getPathWithoutLocale,
} from '../i18n';
import { getNavigation } from '../lib/site-data';

interface Props {
  lang?: Locale;
  alternateUrl?: string;
  theme?: 'light' | 'dark';
}

const { lang = DEFAULT_LOCALE, alternateUrl, theme = 'light' } = Astro.props;
const t = useTranslations(lang);
const isDark = theme === 'dark';

const currentPath = getPathWithoutLocale(Astro.url.pathname);
const showSiteIntro = currentPath === '/';
const switchLang = lang === 'fr' ? 'en' : 'fr';
const switchUrl = alternateUrl || getLocalizedPath(currentPath, switchLang);
const startProjectUrl = getLocalizedPath('/contact', lang);
const languageItems = [
  { locale: 'fr' as const, label: 'Fr', href: switchLang === 'fr' ? switchUrl : getLocalizedPath(currentPath, 'fr') },
  { locale: 'en' as const, label: 'Eng', href: switchLang === 'en' ? switchUrl : getLocalizedPath(currentPath, 'en') },
];

const navigation = await getNavigation(lang);
const {
  logo = '/images/logo.svg',
  logoAlt = 'Logo',
  items = [],
  ctaButton,
} = navigation;

const emailUrl = ctaButton?.url || 'mailto:hello@hordeagence.com';
const emailLabel = ctaButton?.label || 'hello@hordeagence.com';
const textClasses = isDark ? 'text-button-white' : 'text-black';
const desktopLinkClasses = isDark
  ? 'text-button-white/85 hover:text-button-white'
  : 'text-black/70 hover:text-black';

---

{showSiteIntro && (
  <div class="site-intro" data-site-intro aria-hidden="true">
    <div class="site-intro__logo-clip" data-site-intro-logo></div>
  </div>
)}

<header class:list={['site-header fixed inset-x-0 top-0 z-[9999] pointer-events-none', textClasses]} data-theme={theme}>
  <div class="relative z-[3] md:hidden" data-header-surface="mobile">
    <div class="site-header__mobile-fixed pl-[15px] pr-[24px]" data-mobile-fixed>
      <div class="relative z-[5] flex h-full items-center justify-between gap-4" data-mobile-row>
        <div class="flex items-center">
          <a
            href={`/${lang}`}
            class="pointer-events-auto inline-flex items-center text-button-white"
            title={logoAlt}
            aria-label={logoAlt}
          >
            <img
              src={logo}
              alt={logoAlt}
              class="site-header__mobile-logo block h-[12px] w-[41px] max-w-full"
              width="54"
              height="16"
              decoding="async"
            />
          </a>
          <div class="site-header__desktop-breadcrumb site-header__sm-breadcrumb hidden items-center sm:flex md:hidden" data-header-breadcrumb-slot></div>
        </div>

        <button
          type="button"
          class="site-header__menu-toggle pointer-events-auto cursor-pointer relative inline-flex gap-2.5 text-[16px] items-center justify-center bg-transparent p-0 text-current"
          data-header-toggle
          data-open-label={t.nav.openMenu}
          data-close-label={t.nav.closeMenu}
          data-menu-text={t.nav.menu}
          data-close-text={t.nav.close}
          data-menu-open="false"
          aria-expanded="false"
          aria-controls="site-header-mobile-panel"
          aria-label={t.nav.openMenu}
        >
          <span data-header-toggle-label>{t.nav.menu}</span>
          <span class="relative flex h-4 w-[29px] flex-col justify-center" aria-hidden="true">
            <span class="site-header__menu-toggle-line absolute left-0 block h-px w-full bg-current"></span>
            <span class="site-header__menu-toggle-line absolute left-0 block h-px w-full bg-current"></span>
          </span>
        </button>
      </div>

    </div>

    <div
      id="site-header-mobile-panel"
      class:list={[
        'site-header__mobile-panel pointer-events-auto fixed inset-0 z-[2] flex min-h-[100dvh] flex-col bg-[var(--color-black)] px-[15px] pt-[120px] pb-(--gutter) text-button-white',
      ]}
      data-header-panel
      hidden
    >
      <div class="flex flex-1 items-start">
        <nav aria-label="Navigation principale" class="w-full">
          <ul class="site-header__menu-hover-list m-0 flex list-none flex-col items-end gap-[15px] p-0">
            {items.map((item) => (
              <li>
                <a
                  href={item.url}
                  class="site-header__menu-hover-item inline-flex text-right items-center text-[18px] leading-none tracking-[-0.02em] transition-opacity duration-200"
                  target={item.isExternal ? '_blank' : undefined}
                  rel={item.isExternal ? 'noopener noreferrer' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))}
            <li class="ml-auto mt-[20px] h-px w-[25px] bg-lines-dark" aria-hidden="true"></li>
            <li>
              <a
                href={switchUrl}
                hreflang={switchLang}
                class="site-header__menu-hover-item inline-flex gap-2.5 text-right items-center text-[18px] leading-none tracking-[-0.02em] transition-opacity duration-200"
              >
                {t.nav.switchLang}
                <span aria-hidden="true" class="text-[12px]">( ↗ )</span>
              </a>
            </li>
            <li>
              <a
                href={emailUrl}
                class="site-header__menu-hover-item inline-flex gap-2.5 text-right items-center text-[18px] leading-none tracking-[-0.02em] transition-opacity duration-200"
              >
                {emailLabel}
                <span aria-hidden="true" class="text-[12px]">( ↗ )</span>
              </a>
            </li>
            <li>
              <a
                href={startProjectUrl}
                class="site-header__menu-hover-item inline-flex gap-2.5 text-right items-center text-[18px] leading-none tracking-[-0.02em] transition-opacity duration-200"
              >
                {t.nav.startProject}
                <span aria-hidden="true" class="text-[12px]">( ↗ )</span>
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </div>

    <div class="site-header__mobile-reveal" data-header-reveal aria-hidden="true" hidden></div>
  </div>

  <div class="hidden md:block slg:hidden" data-header-surface="tablet">
