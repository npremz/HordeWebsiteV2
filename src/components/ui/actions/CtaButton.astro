---
import { getCtaButtonClasses, type CtaButtonVariant } from './cta-button-classes';

interface Props {
  label: string;
  href?: string;
  onclick?: string;
  variant?: CtaButtonVariant;
  fullWidth?: boolean;
  class?: string;
}

const {
  label,
  href,
  variant = 'dark',
  fullWidth = false,
  class: className,
  ...rest
} = Astro.props;

const { classes, wipe, textHover } = getCtaButtonClasses(variant, fullWidth, className);
---

{href ? (
  <a href={href} title={label} class={classes} {...rest}>
    <span class={wipe} aria-hidden="true"></span>
    <span class={textHover}>{label}</span>
  </a>
) : (
  <button type="button" class={classes} {...rest}>
    <span class={wipe} aria-hidden="true"></span>
    <span class={textHover}>{label}</span>
  </button>
)}
