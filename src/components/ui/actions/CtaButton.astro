---
import { getCtaButtonClasses, type CtaButtonVariant } from './cta-button-classes';

interface Props {
  label: string;
  href?: string;
  onclick?: string;
  variant?: CtaButtonVariant;
  fullWidth?: boolean;
  class?: string;
}

const {
  label,
  href,
  variant = 'dark',
  fullWidth = false,
  class: className,
  ...rest
} = Astro.props;

const {
  classes,
  overlay,
  labelTrack,
  labelBase,
  labelOverlay,
  labelOverlayText,
} = getCtaButtonClasses(variant, fullWidth, className);
---

{href ? (
  <a href={href} title={label} class={classes} {...rest}>
    <span class={overlay} aria-hidden="true"></span>
    <span class={labelTrack}>
      <span class={labelBase}>{label}</span>
    </span>
    <span class={labelOverlay} aria-hidden="true">
      <span class={labelOverlayText}>{label}</span>
    </span>
  </a>
) : (
  <button type="button" class={classes} {...rest}>
    <span class={overlay} aria-hidden="true"></span>
    <span class={labelTrack}>
      <span class={labelBase}>{label}</span>
    </span>
    <span class={labelOverlay} aria-hidden="true">
      <span class={labelOverlayText}>{label}</span>
    </span>
  </button>
)}
