---
import {
  SUPPORTED_LOCALES,
  DEFAULT_LOCALE,
  HREFLANG_LOCALE_CODES,
  OG_LOCALE_CODES,
  type Locale,
  getAlternateUrls,
} from '../i18n';
import { getSiteSettings } from '../lib/site-data';

interface Props {
  // i18n
  lang?: Locale;
  alternateUrl?: string; // URL explicite pour l'autre langue (slugs différents FR/EN)

  // Essential meta
  title: string;
  description: string;
  robots?: 'index, follow' | 'noindex, follow' | 'noindex, nofollow';
  canonical?: string;

  // Open Graph
  ogType?: 'website' | 'article';
  ogImage?: string;
  ogImageAlt?: string;

  // Twitter
  twitterCard?: 'summary' | 'summary_large_image';

  // Article specific (for og:type="article")
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  authorUrl?: string;

  // Override site defaults
  siteName?: string;
  twitterSite?: string;

  // Title format
  siteNameAsPrefix?: boolean;
}

// Theme colors (hardcoded)
const THEME_COLOR_LIGHT = '#ffffff';
const THEME_COLOR_DARK = '#1a1a1a';

// Get lang from props, default to 'fr'
const lang = Astro.props.lang || DEFAULT_LOCALE;
const ogLocale = OG_LOCALE_CODES[lang];
const siteSettings = await getSiteSettings(lang);

// Get alternate URLs for hreflang
const siteUrl = Astro.site?.href || 'https://hordeagence.com';
const baseAlternateUrls = getAlternateUrls(Astro.url.pathname, siteUrl);

// Si alternateUrl est fourni, l'utiliser pour l'autre langue
const alternateUrlProp = Astro.props.alternateUrl;
const switchLang = lang === 'fr' ? 'en' : 'fr';
const alternateUrls = alternateUrlProp
  ? { ...baseAlternateUrls, [switchLang]: alternateUrlProp }
  : baseAlternateUrls;

const {
  title,
  description,
  robots = 'index, follow',
  canonical,
  ogType = 'website',
  ogImage,
  ogImageAlt,
  twitterCard = 'summary_large_image',
  publishedTime,
  modifiedTime,
  author,
  authorUrl,
  siteName = siteSettings.siteName,
  twitterSite = siteSettings.twitterSite,
  siteNameAsPrefix = false,
} = Astro.props;

// Build full title with template
const fullTitle = siteNameAsPrefix
  ? `${siteName} | ${title}`
  : `${title} | ${siteName}`;

// Resolve canonical URL
const canonicalURL = canonical
  ? new URL(canonical, Astro.site).href
  : new URL(Astro.url.pathname, Astro.site).href;

// Resolve OG image URL
const ogImageURL = ogImage
  ? new URL(ogImage, Astro.site).href
  : new URL(siteSettings.defaultOgImage, Astro.site).href;

const resolvedOgImageAlt = ogImageAlt || siteSettings.defaultOgImageAlt;
const normalizedSiteUrl = siteUrl.replace(/\/$/, '');
const organizationId = `${normalizedSiteUrl}#organization`;
const websiteId = `${normalizedSiteUrl}#website`;
const llmsTxtURL = new URL('/llms.txt', Astro.site).href;
const llmsFullTxtURL = new URL('/llms-full.txt', Astro.site).href;
const sameAs = [
  'https://www.linkedin.com/company/horde-agence/',
  'https://www.instagram.com/hordeagencebxl/',
  'https://github.com/npremz',
];
---

<!-- Essential Meta Tags -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="robots" content={robots} />
<link rel="canonical" href={canonicalURL} />
{authorUrl && <link rel="author" href={authorUrl} />}
<link rel="alternate" type="text/plain" title="LLMs.txt" href={llmsTxtURL} />
<link rel="alternate" type="text/plain" title="LLMs Full" href={llmsFullTxtURL} />

<!-- Hreflang for internationalization -->
{SUPPORTED_LOCALES.map((locale) => (
  <link rel="alternate" hreflang={HREFLANG_LOCALE_CODES[locale]} href={alternateUrls[locale]} />
))}
<link rel="alternate" hreflang="x-default" href={alternateUrls[DEFAULT_LOCALE]} />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:image:alt" content={resolvedOgImageAlt} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:type" content={ogType} />
<meta property="og:locale" content={ogLocale} />
{SUPPORTED_LOCALES.filter(l => l !== lang).map((locale) => (
  <meta property="og:locale:alternate" content={OG_LOCALE_CODES[locale]} />
))}
<meta property="og:site_name" content={siteName} />

{ogType === 'article' && publishedTime && (
  <meta property="article:published_time" content={publishedTime} />
)}
{ogType === 'article' && modifiedTime && (
  <meta property="article:modified_time" content={modifiedTime} />
)}
{ogType === 'article' && author && (
  <meta property="article:author" content={author} />
)}

<!-- Twitter Card -->
<meta name="twitter:card" content={twitterCard} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />
<meta name="twitter:image:alt" content={resolvedOgImageAlt} />
{twitterSite && <meta name="twitter:site" content={twitterSite} />}

<!-- Favicon & App Icons -->
<link rel="icon" href="/favicons/favicon.ico" sizes="32x32" />
<link rel="icon" href="/favicons/favicon.svg" type="image/svg+xml" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicons/favicon-16x16.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicons/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="96x96" href="/favicons/favicon-96x96.png" />

<!-- Apple Touch Icons -->
<link rel="apple-touch-icon" href="/favicons/apple-icon.png" />
<link rel="apple-touch-icon" sizes="57x57" href="/favicons/apple-icon-57x57.png" />
<link rel="apple-touch-icon" sizes="60x60" href="/favicons/apple-icon-60x60.png" />
<link rel="apple-touch-icon" sizes="72x72" href="/favicons/apple-icon-72x72.png" />
<link rel="apple-touch-icon" sizes="76x76" href="/favicons/apple-icon-76x76.png" />
<link rel="apple-touch-icon" sizes="114x114" href="/favicons/apple-icon-114x114.png" />
<link rel="apple-touch-icon" sizes="120x120" href="/favicons/apple-icon-120x120.png" />
<link rel="apple-touch-icon" sizes="144x144" href="/favicons/apple-icon-144x144.png" />
<link rel="apple-touch-icon" sizes="152x152" href="/favicons/apple-icon-152x152.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-icon-180x180.png" />

<!-- Android Icons -->
<link rel="icon" type="image/png" sizes="192x192" href="/favicons/android-icon-192x192.png" />

<!-- Microsoft -->
<meta name="msapplication-TileColor" content={THEME_COLOR_DARK} />
<meta name="msapplication-TileImage" content="/favicons/ms-icon-144x144.png" />
<meta name="msapplication-config" content="/favicons/browserconfig.xml" />

<!-- Manifest -->
<link rel="manifest" href="/favicons/manifest.json" />

<!-- Theme Color (light & dark mode) -->
<meta name="theme-color" content={THEME_COLOR_LIGHT} media="(prefers-color-scheme: light)" />
<meta name="theme-color" content={THEME_COLOR_DARK} media="(prefers-color-scheme: dark)" />

<!-- Structured Data - Organization / ProfessionalService -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": organizationId,
      "name": siteName,
      "alternateName": "Horde Bruxelles",
      "url": Astro.site?.href,
      "logo": new URL("/images/logo.svg", Astro.site).href,
      "image": new URL(siteSettings.defaultOgImage, Astro.site).href,
      "email": "hello@hordeagence.com",
      "sameAs": sameAs
    },
    {
      "@type": "ProfessionalService",
      "@id": `${normalizedSiteUrl}#service`,
      "name": siteName,
      "description": "Horde Agence, agence web à Bruxelles spécialisée en sites web rapides et sur mesure",
      "url": Astro.site?.href,
      "image": new URL(siteSettings.defaultOgImage, Astro.site).href,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Bruxelles",
        "addressRegion": "Bruxelles-Capitale",
        "addressCountry": "BE"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 50.8503,
        "longitude": 4.3517
      },
      "areaServed": [
        {
          "@type": "City",
          "name": "Bruxelles"
        },
        {
          "@type": "Country",
          "name": "Belgique"
        }
      ],
      "priceRange": "$$",
      "email": "hello@hordeagence.com",
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer service",
        "url": `${normalizedSiteUrl}/fr/contact`,
        "email": "hello@hordeagence.com",
        "availableLanguage": ["fr-BE", "en-US"]
      },
      "sameAs": sameAs,
      "provider": {
        "@id": organizationId
      },
      "knowsAbout": [
        "Web Performance",
        "User Experience",
        "UX Design",
        "Web Development",
        "Core Web Vitals",
        "SEO",
        "Interface Design"
      ],
      "slogan": "Interfaces ultra-rapides qui convertissent"
    }
  ],
})} />

<!-- Structured Data - WebSite -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": websiteId,
  "name": siteName,
  "url": Astro.site?.href,
  "publisher": {
    "@id": organizationId
  },
  "inLanguage": ["fr-BE", "en-US"]
})} />

<!-- Structured Data - WebPage -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": canonicalURL,
  "image": ogImageURL,
  "isPartOf": {
    "@id": websiteId
  },
  "about": {
    "@id": organizationId
  },
  "inLanguage": siteSettings.locale.replace('_', '-'),
  ...(ogType === "article" && publishedTime ? {
    "datePublished": publishedTime,
    "dateModified": modifiedTime || publishedTime,
    "author": author ? {
      "@type": "Person",
      "name": author,
      ...(authorUrl ? { "url": authorUrl } : {})
    } : undefined
  } : {})
})} />
