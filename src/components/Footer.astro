---
import PhysicsWordmark from "./ui/effects/PhysicsWordmark.astro";
import { DEFAULT_LOCALE, type Locale, useTranslations } from "../i18n";
import { getSiteChrome } from "../lib/site-data";
import { getFooterServiceLinks } from "../lib/content/services";

interface Props {
	lang?: Locale;
	variant?: "light" | "dark";
	hideOverflow?: boolean;
	innerBg?: boolean;
}

const {
	lang = DEFAULT_LOCALE,
	variant = "light",
	hideOverflow = true,
	innerBg = false,
} = Astro.props;
const t = useTranslations(lang);
const isDark = variant === "dark";
const { footer, navigation } = await getSiteChrome(lang);
const serviceLinks = await getFooterServiceLinks(lang);

// Extraire les données
const {
	description,
	columns = [],
	legalLinks = [],
	copyright,
} = footer;
const ctaColumn = columns.find((col) => col.title === "CTAs");
const { logo, logoAlt = "Logo", items: menuItems = [] } = navigation;

// Dark mode colors
const currentLogo = isDark ? "/images/logo_white.svg" : logo;
const strokeColor = isDark ? "#4C4B4B" : "#B1B1B1";
const textColorClass = isDark ? "text-button-white" : "text-black";
---

<footer
	class:list={["relative", textColorClass]}
	id="footer-parallax"
	data-variant={variant}
>
	<PhysicsWordmark dark={variant == "dark" && true} hideOverflow={hideOverflow} />

	<div class:list={[innerBg && "footer-inner-bg", "py-16 lg:pt-24"]}>
	<a
		href={`/${lang}/contact`}
		class="footer-logo-wrapper footer-svg-parallax z-9999 block"
		aria-label={t.footer.contactAriaLabel}
		title={t.footer.contactAriaLabel}
	>
		<svg
			class="footer-logo relative w-full sm:w-[calc(100vw-4rem)] sm:max-w-none! sm:left-1/2 sm:-translate-x-1/2 md:w-[calc(100vw-8rem)]"
			viewBox="0 0 281 43"
			fill="none"
			xmlns="http://www.w3.org/2000/svg"
			aria-hidden="true"
		>
			<path
				d="M3.11089 42.4164C2.13059 42.4541 1.35767 42.1902 0.792121 41.6246C0.264272 41.0591 0.000347299 40.2861 0.000347299 39.3058V1.97938H3.73299V39.2493L23.9232 38.6837V41.8508L3.11089 42.4164ZM52.4925 41.8508H28.5696V1.97938H52.4925V5.14647H32.3022V20.3033H49.6647V23.4704H32.3022V38.6837H52.4925V41.8508ZM56.5468 1.97938H88.2742V5.14647H74.3051V41.8508H70.5725V5.14647H56.5468V1.97938ZM91.7966 13.1208L95.303 -5.13511e-05L98.9225 0.961386L95.4161 14.0822L91.7966 13.1208ZM135.051 31.9537C135.051 35.1585 133.92 37.7034 131.657 39.5886C129.395 41.4738 125.531 42.4164 120.064 42.4164C113.541 42.4164 108.96 41.0968 106.321 38.4575C103.719 35.8183 102.418 32.0102 102.418 27.0334H106.151C106.151 30.2759 106.698 32.7831 107.791 34.5552C108.885 36.3273 110.43 37.5526 112.429 38.2313C114.465 38.91 117.01 39.2493 120.064 39.2493C123.759 39.2493 126.549 38.7214 128.434 37.6657C130.357 36.5723 131.318 34.7626 131.318 32.2364C131.318 30.389 130.771 28.8997 129.678 27.7686C128.622 26.5998 127.322 25.6949 125.776 25.0539C124.23 24.413 122.137 23.7343 119.498 23.0179C118.442 22.754 117.745 22.5655 117.406 22.4524C114.389 21.5852 111.957 20.7369 110.11 19.9074C108.3 19.0402 106.867 17.9091 105.812 16.5141C104.756 15.1191 104.228 13.3281 104.228 11.1413C104.228 8.04964 105.34 5.65547 107.565 3.95882C109.827 2.26216 113.315 1.41383 118.028 1.41383C121.685 1.41383 124.663 2.09249 126.963 3.44982C129.263 4.76944 130.903 6.44724 131.884 8.48323C132.902 10.5192 133.411 12.6872 133.411 14.9871H129.678C129.678 11.5938 128.585 9.01108 126.398 7.23902C124.211 5.46695 121.421 4.58092 118.028 4.58092C114.861 4.58092 112.391 5.07107 110.619 6.05136C108.847 6.99395 107.961 8.6152 107.961 10.9151C107.961 12.4232 108.357 13.6675 109.148 14.6478C109.978 15.628 111.109 16.4575 112.542 17.1362C114.012 17.7771 116.01 18.4935 118.537 19.2853L120.29 19.7943C123.608 20.8123 126.228 21.736 128.151 22.5655C130.074 23.395 131.695 24.5826 133.015 26.1285C134.372 27.6366 135.051 29.5783 135.051 31.9537ZM156.188 1.97938H187.915V5.14647H173.946V41.8508H170.214V5.14647H156.188V1.97938ZM217.462 41.8508H213.786L208.47 25.676H192.521L187.205 41.8508H183.529L196.65 1.97938H204.341L217.462 41.8508ZM199.93 3.11048L193.539 22.5089H207.452L201.061 3.11048H199.93ZM224.651 42.4164C223.67 42.4541 222.897 42.1902 222.332 41.6246C221.804 41.0591 221.54 40.2861 221.54 39.3058V1.97938H225.273V39.2493L245.463 38.6837V41.8508L224.651 42.4164ZM275.22 1.97938H280.593L256.217 21.8868L280.593 41.8508H275.22L253.842 24.3187V41.8508H250.109V1.97938H253.842V19.5115L275.22 1.97938Z"
				fill="currentColor"></path>
		</svg>
	</a>

	<div
		class="section-spacing mt-16 sm:mt-24 2xl:mt-32 flex-col-container  lg:grid lg:grid-cols-12 lg:gap-0 lg:w-full"
	>
		<!-- Description -->
		{
			description && (
				<div class="flex-col-container column-gap lg:col-span-5">
					<p class="text-2xl leading-tight sm:text-[1.5rem] sm:max-w-[380px]">
						{description}
					</p>
				</div>
			)
		}

		<div
			class="flex-col-container sm:flex-row sm:justify-between mt-16 sm:mt-24 lg:mt-0 lg:col-span-7 lg:grid lg:grid-cols-7 lg:gap-0"
		>
			<!-- CTAs -->
			{
				ctaColumn && (
					<div class="flex-col-container column-gap lg:col-span-3">
						<ul class="flex flex-wrap max-w-[288px] gap-5 text-[1.125rem] leading-tight">
							{ctaColumn.links.map((link) => (
								<li>
									<a
										href={link.url}
										class="footer-link-cta"
										target={
											link.isExternal
												? "_blank"
												: undefined
										}
										rel={
											link.isExternal
												? "noopener noreferrer"
												: undefined
										}
										title={link.label}
									>
										<span class="footer-link__text">
											<span class="footer-link__text-base">{link.label}</span>
											<span class="footer-link__text-overlay" aria-hidden="true">{link.label}</span>
										</span>
									</a>
								</li>
							))}
						</ul>
					</div>
				)
			}

			<!-- Menu -->
			<div
				class="flex-col-container flex-row justify-between mt-16 sm:mt-0 column-gap gap-8 sm:gap-24 lg:col-span-4 lg:justify-self-end"
			>

				<ul class="flex-col-container gap-[10px] text-[1.125rem]">
					{
						menuItems.map((item) => (
							<li class="">
								<a
									href={item.url}
									class="footer-link"
									target={
										item.isExternal ? "_blank" : undefined
									}
									rel={
										item.isExternal
										? "noopener noreferrer"
											: undefined
									}
									title={item.label}
									>
									<span class="footer-link__text">
										<span class="footer-link__text-base">{item.label}</span>
										<span class="footer-link__text-overlay" aria-hidden="true">{item.label}</span>
									</span>
								</a>
							</li>
						))
					}
				</ul>
				{
					serviceLinks.length > 0 && (
						<ul
							class="flex-col-container gap-[10px] text-[1.125rem] items-end"
							aria-label="Services"
						>
							{serviceLinks.map((link) => (
								<li>
									<a
										href={link.url}
										class="footer-link"
										title={link.label}
									>
										<span class="footer-link__text">
											<span class="footer-link__text-base">{link.label}</span>
											<span class="footer-link__text-overlay" aria-hidden="true">{link.label}</span>
										</span>
									</a>
								</li>
							))}
						</ul>
					)
				}
			</div>
		</div>

		<!-- Logo -->
		<div
			class="relative flex-col-container flex-row items-end justify-between mt-16 sm:mt-24 lg:mt-50 lg:col-span-12"
		>
			<div class="sm:absolute sm:left-1/2 sm:-translate-x-1/2">
				{
					currentLogo ? (
						<a href={`/${lang}`} class="" title={logoAlt}>
							<img
								src={currentLogo}
								alt={logoAlt}
								class="logo-size w-12"
								loading="lazy"
								decoding="async"
							/>
						</a>
					) : (
						<a
							href={`/${lang}`}
							class="text-xl font-display"
							title={logoAlt}
						>
							{logoAlt}
						</a>
					)
				}
			</div>
			<!-- Copyright et liens légaux -->
			<div
				class="flex-col-container sm:w-full sm:flex-row gap-2 sm:mt-0 text-[1.125rem] sm:justify-between sm:items-end"
			>
				<div
					class="flex-col-container items-end sm:items-start lg:flex-row gap-3 leading-tight"
				>
					{
						legalLinks.map((link) => (
							<a href={link.url} class="footer-link" title={link.label}>
								<span class="footer-link__text">
									<span class="footer-link__text-base">{link.label}</span>
									<span class="footer-link__text-overlay" aria-hidden="true">{link.label}</span>
								</span>
							</a>
						))
					}
				</div>
				{
					copyright && (
						<span class="md:max-w-[200px]">
							{copyright}
						</span>
					)
				}
			</div>
		</div>
	</div>
	</div>
</footer>

<style>
	.footer-inner-bg {
		position: relative;
	}
	.footer-inner-bg::before {
		content: "";
		position: absolute;
		top: 0;
		bottom: 0;
		left: -100vw;
		right: -100vw;
		z-index: -1;
		background-color: var(--color-bg);
	}

	.footer-logo-wrapper {
		position: relative;
		cursor: pointer;
		overflow: visible;
	}

	.footer-logo-wrapper::before {
		content: "";
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%) scaleY(0);
		transform-origin: center bottom;
		width: calc(100vw - 32px);
		height: calc(100% + 60px);
		background-color: var(--color-black);
		z-index: -1;
		transition: transform 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94);
	}

	[data-variant="dark"] .footer-logo-wrapper::before {
		background-color: var(--color-button-white);
	}

	@media (min-width: 640px) {
		.footer-logo-wrapper::before {
			width: calc(100vw - 60px);
		}
	}

	.footer-logo-wrapper:hover::before {
		transform: translate(-50%, -50%) scaleY(1);
	}

	.footer-logo {
		color: currentColor;
		display: block;
		transition: color 0.15s ease-out 0.1s;
	}

	.footer-logo-wrapper:hover .footer-logo {
		color: var(--color-button-white);
	}

	[data-variant="dark"] .footer-logo-wrapper:hover .footer-logo {
		color: var(--color-black);
	}

	/* Footer links avec animation verticale du texte */
	.footer-link,
	.footer-link-cta {
		position: relative;
		display: inline-block;
		overflow: hidden;
	}

	.footer-link__text {
		position: relative;
		display: block;
		overflow: hidden;
	}

	.footer-link__text-base,
	.footer-link__text-overlay {
		display: block;
		transition: transform 0.15s ease-out;
	}

	.footer-link__text-overlay {
		position: absolute;
		inset: 0;
		transform: translateY(100%);
	}

	[data-variant="dark"] .footer-link-cta {
		border-bottom-color: var(--color-lines-dark);
	}

	.footer-link-cta {
		border-bottom: 1px solid var(--color-lines);
	}

	@media (hover: hover) {
		.footer-link:hover .footer-link__text-base,
		.footer-link-cta:hover .footer-link__text-base {
			transform: translateY(-100%);
		}

		.footer-link:hover .footer-link__text-overlay,
		.footer-link-cta:hover .footer-link__text-overlay {
			transform: translateY(0);
		}
	}
</style>
