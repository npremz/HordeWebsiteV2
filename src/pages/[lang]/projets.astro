---
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import ProjectsListingPage from "../../components/projects/ProjectsListingPage.astro";
import { SUPPORTED_LOCALES, type Locale, useTranslations } from "../../i18n";
import { getLocalizedProjects } from "../../lib/content/projects";
import {
  getProjectServiceEntries,
  getProjectIndexHref,
  getProjectServiceHref,
  getLocalizedProjectServiceLabel,
} from "../../lib/projectServices";

export const prerender = true;

export function getStaticPaths() {
  return SUPPORTED_LOCALES.map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);
const projectFilterLabels: Record<string, { fr: string; en: string }> = {
  'creation-ecommerce': { fr: 'E-commerce', en: 'E-commerce' },
  'optimisation-site-web': { fr: 'Optimisation', en: 'Optimization' },
  'creation-landing-page': { fr: 'Landing Page', en: 'Landing Page' },
  'creation-mvp-saas': { fr: 'Saas Mvp', en: 'Saas Mvp' },
  'refonte-site-web': { fr: 'Refonte', en: 'Redesign' },
};

const projects = await getLocalizedProjects(lang);

const projectOrder: Record<string, number> = {
  "cafe-belga": 1,
  "e-putch": 2,
  merly: 3,
};

const orderedProjects = [...projects].sort(
  (a, b) => (projectOrder[a.slug] || a.order) - (projectOrder[b.slug] || b.order),
);

const projectServices = await getProjectServiceEntries();
const listedProjects = orderedProjects.filter((project) => !project.inProgress);
const serviceFilters = projectServices
  .filter((service) =>
    listedProjects.some((project) => project.services.includes(service.data.slug)),
  )
  .map((service) => ({
    label: projectFilterLabels[service.data.slug]?.[lang] || getLocalizedProjectServiceLabel(service, lang),
    href: getProjectServiceHref(service.data.slug, lang),
  }));
---

<Layout lang={lang} title={t.projectsPage.title} description={t.projectsPage.description} variant="dark" headerVariant="dark" showContainerLines={false}>
  <div class="fixed inset-0 -z-10 bg-black" aria-hidden="true"></div>

  <ProjectsListingPage
    projects={orderedProjects}
    lang={lang}
    intro={t.projectsPage.intro}
    allLabel={t.projectsPage.all}
    filters={serviceFilters}
    activeHref={getProjectIndexHref(lang)}
    variant="dark"
  />

  <Footer lang={lang} variant="dark" hideOverflow={false} />
</Layout>
