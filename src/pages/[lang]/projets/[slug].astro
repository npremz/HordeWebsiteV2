---
import { Image } from 'astro:assets';
import Layout from '../../../layouts/Layout.astro';
import Footer from '../../../components/Footer.astro';
import ProjectsShapeBand from '../../../components/projects/ProjectsShapeBand.astro';
import Breadcrumbs from '../../../components/ui/navigation/Breadcrumbs.astro';
import { SUPPORTED_LOCALES, type Locale } from '../../../i18n';
import {
  type LocalizedProject,
  type LocalizedProjectGalleryRow,
  type ProjectEntry,
  getLocalizedProjectDescription,
  getLocalizedProjects,
  getProjects,
  localizeProject,
} from '../../../lib/content/projects';

export const prerender = true;

export async function getStaticPaths() {
  const projects = await getProjects();

  return SUPPORTED_LOCALES.flatMap((lang) =>
    projects
      .filter((project) => !project.data.inProgress)
      .map((project) => ({
        params: { lang, slug: project.data.slug },
        props: { project, lang },
      }))
  );
}

const { project, lang } = Astro.props as { project: ProjectEntry; lang: Locale };
const localizedProject = localizeProject(project, lang);
const descriptionContent = await getLocalizedProjectDescription(project.data.slug, lang);
const allProjects = await getLocalizedProjects(lang);

const {
  fullTitle,
  shortTitle,
  seoDescription,
  gallery,
  projectTypes,
  externalUrl,
} = localizedProject;

const projectOrder: Record<string, number> = {
  'cafe-belga': 1,
  'e-putch': 2,
  merly: 3,
};

const displayMetaBySlug: Record<string, { type: string }> = {
  'cafe-belga': { type: 'Landing page' },
  'e-putch': { type: 'Landing page' },
  merly: { type: 'Case study' },
};

const orderedProjects = [...allProjects].sort(
  (a, b) => (projectOrder[a.slug] || a.order) - (projectOrder[b.slug] || b.order),
);
const otherProjects = orderedProjects.filter((item) => item.slug !== localizedProject.slug);

const copy = {
  fr: {
    allWork: 'ALL WORK',
    breadcrumbHome: 'Accueil',
    breadcrumbProjects: 'Projets',
    filterLabel: 'Filtre par service',
    viewSite: 'Voir le site',
  },
  en: {
    allWork: 'ALL WORK',
    breadcrumbHome: 'Home',
    breadcrumbProjects: 'Projects',
    filterLabel: 'Filter by service',
    viewSite: 'View website',
  },
} satisfies Record<Locale, Record<string, string>>;

const projectTitle = shortTitle.toUpperCase();
const projectYear = new Date(project.data.publishedDate).getFullYear();
const yearLabel = Number.isFinite(projectYear) ? String(projectYear) : '';
const serviceLabel = displayMetaBySlug[localizedProject.slug]?.type || projectTypes[0] || '';
const projectTypeCount = `(${projectTypes.length || 1})`;
const projectCount = `(${String(orderedProjects.length).padStart(2, '0')})`;
const descriptionParagraphs = descriptionContent.split(/\n\n+/).map((paragraph) => paragraph.trim()).filter(Boolean);
const breadcrumbItems = [
  { label: copy[lang].breadcrumbHome, href: `/${lang}` },
  { label: copy[lang].breadcrumbProjects, href: `/${lang}/projets` },
  { label: shortTitle },
];

function getProjectNavTitle(projectItem: LocalizedProject): string {
  return projectItem.shortTitle.replace(/-/g, '').toUpperCase();
}
---

<Layout
  lang={lang}
  title={fullTitle}
  description={seoDescription}
  variant="dark"
  headerVariant="dark"
>
  <div class="fixed inset-0 -z-10 bg-black" aria-hidden="true"></div>

  <article id="page-content" class="project-single relative z-10 text-bg-light">
    <section class="project-hero relative isolate min-h-[830px] pt-28 sm:min-h-[900px] sm:pt-36 md:min-h-[780px] lg:min-h-[860px] lg:pt-42 2xl:min-h-[980px]" aria-labelledby="project-title">
      <ProjectsShapeBand class="project-single-shape top-8 h-[310px] sm:top-12 sm:h-[390px] md:h-[430px] lg:top-16 lg:h-[470px] 2xl:h-[640px]" />
      
      <div class="relative mx-auto grid w-full max-w-[1300px] grid-cols-2 gap-x-5 gap-y-10 px-4 text-[0.7rem] leading-tight sm:px-8 sm:text-[0.78rem] md:grid-cols-[1fr_minmax(220px,1fr)_1fr] md:px-10 lg:px-0">
        <p class="font-mono uppercase text-bg-light/80 md:pt-28">{yearLabel}</p>

        <div class="col-span-2 flex flex-col items-center gap-4 text-center md:col-span-1 md:col-start-2 md:row-start-1 md:pt-24">
          <Breadcrumbs
            items={breadcrumbItems}
            variant="dark"
            class="hidden sm:block"
            ariaLabel={lang === 'fr' ? 'Fil d’Ariane' : 'Breadcrumb'}
          />
          <h1 id="project-title" class="flex gap-8 items-center font-display text-[2rem] uppercase leading-none tracking-normal sm:text-[2.5rem] lg:text-[3rem]">
            <svg width="7" height="35" viewBox="0 0 7 35" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M5.12291 0H7C4.22346 4.85665 2.15084 10.1548 2.15084 17.5803C2.15084 24.8452 4.22346 30.1433 7 35H5.12291C2.42458 30.9461 0 24.8452 0 17.5803C0 10.0745 2.42458 4.0539 5.12291 0Z" fill="white"/>
            </svg>
            <span class="mt-1.5">{projectTitle}</span>
            <svg width="8" height="35" viewBox="0 0 8 35" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1.95539 35L8.10623e-05 35C2.89231 30.1433 5.05129 24.8452 5.05129 17.4197C5.05129 10.1548 2.89231 4.85665 8.42496e-05 -6.1196e-07L1.95539 -4.47859e-07C4.76615 4.0539 7.29175 10.1548 7.29175 17.4197C7.29175 24.9255 4.76614 30.9461 1.95539 35Z" fill="white"/>
            </svg>

          </h1>
        </div>

        <div class="flex items-start justify-end gap-4 md:pt-28">
          {externalUrl && (
            <a
              href={externalUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="project-external-link font-mono uppercase text-bg-light/85 underline decoration-bg-light/60 decoration-[1px] underline-offset-3 transition-opacity duration-200 hover:opacity-65"
              title={copy[lang].viewSite}
            >
              {copy[lang].viewSite} (↗)
            </a>
          )}
        </div>

        <div class="col-span-2 flex items-start justify-between gap-6 font-mono uppercase text-bg-light/75 md:col-span-1 md:col-start-1 md:row-start-2 md:mt-10 md:block">
          <p>{copy[lang].filterLabel}</p>
          {serviceLabel && <p class="mt-0 underline decoration-bg-light/50 decoration-[1px] underline-offset-3 md:mt-5">{serviceLabel}</p>}
        </div>

        {descriptionParagraphs.length > 0 && (
          <div class="col-span-2 max-w-[470px] text-[0.92rem] leading-[1.32] text-bg-light/86 sm:text-[1rem] md:col-span-1 md:col-start-3 md:row-start-2 md:mt-10 md:max-w-[430px]">
            {descriptionParagraphs.map((paragraph: string) => (
              <p class="mb-5 last:mb-0" set:html={paragraph} />
            ))}
          </div>
        )}

        <p class="col-span-2 mt-4 font-mono uppercase text-bg-light/75 md:col-span-1 md:col-start-1 md:row-start-3 md:mt-14">
          {projectTypeCount}
        </p>
      </div>
    </section>

    {gallery.length > 0 && (
      <section class="project-gallery mx-auto grid w-full max-w-[640px] grid-cols-2 gap-2.5 sm:gap-4 lg:gap-5 xl:max-w-[1040px]" aria-label={shortTitle}>
        {gallery.map((row: LocalizedProjectGalleryRow, index: number) => {
          const isFirst = index === 0;

          return row.layout === 'full' ? (
            <Image
              src={row.image1}
              alt={row.alt1}
              class="col-span-2 block h-auto w-full"
              widths={[360, 640, 900, 1200]}
              sizes="(max-width: 640px) calc(100vw - 2rem), (max-width: 1919px) 640px, 1040px"
              loading={isFirst ? 'eager' : 'lazy'}
              fetchpriority={isFirst ? 'high' : 'auto'}
              decoding="async"
              format="webp"
              quality={82}
            />
          ) : (
            <>
              <Image
                src={row.image1}
                alt={row.alt1}
                class="block h-auto w-full"
                widths={[180, 320, 520, 700]}
                sizes="(max-width: 640px) calc((100vw - 2.625rem) / 2), (max-width: 1919px) 310px, 510px"
                loading={isFirst ? 'eager' : 'lazy'}
                fetchpriority={isFirst ? 'high' : 'auto'}
                decoding="async"
                format="webp"
                quality={82}
              />
              {row.image2 && (
                <Image
                  src={row.image2}
                  alt={row.alt2 || row.alt1}
                  class="block h-auto w-full"
                  widths={[180, 320, 520, 700]}
                  sizes="(max-width: 640px) calc((100vw - 2.625rem) / 2), (max-width: 1919px) 310px, 510px"
                  loading={isFirst ? 'eager' : 'lazy'}
                  fetchpriority={isFirst ? 'high' : 'auto'}
                  decoding="async"
                  format="webp"
                  quality={82}
                />
              )}
            </>
          );
        })}
      </section>
    )}

    <nav class="project-work-nav mx-auto mt-16 w-full max-w-[1040px] border-t border-lines-dark text-center text-bg-light sm:mt-20 lg:mt-24" aria-label={copy[lang].allWork}>
      <a
        href={`/${lang}/projets`}
        class="group grid min-h-[64px] place-items-center border-b border-lines-dark font-display text-[1.35rem] uppercase leading-none transition-colors duration-300 hover:bg-bg-light hover:text-black sm:min-h-[82px] sm:text-[2rem]"
        title={copy[lang].allWork}
      >
        <span>
          {copy[lang].allWork}
          <span class="ml-2 align-middle font-mono text-[0.62rem] tracking-normal">{projectCount}</span>
        </span>
      </a>

      {otherProjects.map((projectItem) => {
        const href = projectItem.inProgress ? undefined : `/${lang}/projets/${projectItem.slug}`;
        const RowTag = projectItem.inProgress ? 'div' : 'a';

        return (
          <RowTag
            href={href}
            class:list={[
              'grid min-h-[64px] place-items-center border-b border-lines-dark font-display text-[1.25rem] uppercase leading-none transition-colors duration-300 sm:min-h-[82px] sm:text-[1.85rem]',
              !projectItem.inProgress && 'hover:bg-bg-light hover:text-black',
            ]}
            title={projectItem.shortTitle}
          >
            {getProjectNavTitle(projectItem)}
          </RowTag>
        );
      })}
    </nav>
  </article>

  <Footer lang={lang} variant="dark" hideOverflow={false} />
</Layout>

<style>
  :global(.project-single-shape) {
    color: var(--color-lines-dark);
    opacity: 0.72;
  }

  .project-hero::after {
    content: "";
    pointer-events: none;
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, transparent calc(50% - 0.5px), rgb(76 75 75 / 0.55) 50%, transparent calc(50% + 0.5px)),
      linear-gradient(45deg, transparent calc(50% - 0.5px), rgb(76 75 75 / 0.38) 50%, transparent calc(50% + 0.5px));
    opacity: 0.32;
    z-index: 0;
  }

  .project-hero > :not(.project-single-shape) {
    position: relative;
    z-index: 1;
  }

  .project-gallery :global(img) {
    background: #1d181a;
  }

  .project-work-nav :global(a),
  .project-work-nav :global(div) {
    letter-spacing: 0;
  }

  @media (max-width: 1023px) {
    .project-hero::after {
      background:
        linear-gradient(135deg, transparent calc(50% - 0.5px), rgb(76 75 75 / 0.45) 50%, transparent calc(50% + 0.5px));
      opacity: 0.28;
    }
  }
</style>
