---
import { Image } from 'astro:assets';
import Layout from '../../../layouts/Layout.astro';
import Footer from '../../../components/Footer.astro';
import ProjectsShapeBand from '../../../components/projects/ProjectsShapeBand.astro';
import ProjectsListingPage from '../../../components/projects/ProjectsListingPage.astro';
import Breadcrumbs from '../../../components/ui/navigation/Breadcrumbs.astro';
import { SUPPORTED_LOCALES, type Locale } from '../../../i18n';
import {
  type LocalizedProjectGalleryRow,
  type ProjectEntry,
  getLocalizedProjectDescription,
  getLocalizedProjects,
  getProjects,
  localizeProject,
} from '../../../lib/content/projects';
import {
  type ProjectServiceSlug,
  type ProjectService,
  getProjectServiceDescription,
  getProjectServiceEntries,
  getProjectServiceHref,
  getProjectServiceIntro,
  getProjectServiceLabel,
  getProjectServiceTitle,
  getProjectServices,
  projectHasService,
} from '../../../lib/projectServices';

export const prerender = true;

type ProjectPageProps = {
  kind: 'project';
  project: ProjectEntry;
  lang: Locale;
};

type ServicePageProps = {
  kind: 'service';
  service: ProjectService;
  lang: Locale;
};

export async function getStaticPaths() {
  const projects = await getProjects();
  const services = await getProjectServiceEntries();
  const projectSlugs = new Set(projects.map((project) => project.data.slug));

  const projectPaths = SUPPORTED_LOCALES.flatMap((lang) =>
    projects
      .filter((project) => !project.data.inProgress)
      .map((project) => ({
        params: { lang, slug: project.data.slug },
        props: { kind: 'project', project, lang },
      })),
  );

  const servicePaths = SUPPORTED_LOCALES.flatMap((lang) =>
    services
      .filter((service) => !projectSlugs.has(service.data.slug))
      .map((service) => ({
        params: { lang, slug: service.data.slug },
        props: { kind: 'service', service, lang },
      })),
  );

  return [...projectPaths, ...servicePaths];
}

const props = Astro.props as ProjectPageProps | ServicePageProps;
const { lang } = props;

const copy = {
  fr: {
    breadcrumbHome: 'Accueil',
    breadcrumbProjects: 'Projets',
    projectServices: 'Services liés à ce projet',
    projectTypes: 'Types de projet',
    externalUrl: 'Voir le site',
    gallery: 'Galerie',
    allProjects: 'Tous',
  },
  en: {
    breadcrumbHome: 'Home',
    breadcrumbProjects: 'Projects',
    projectServices: 'Services related to this project',
    projectTypes: 'Project types',
    externalUrl: 'View website',
    gallery: 'Gallery',
    allProjects: 'All',
  },
} satisfies Record<Locale, Record<string, string>>;

const allLocalizedProjects = await getLocalizedProjects(lang);
const projectServices = await getProjectServiceEntries();
const serviceFilters = projectServices.map((service) => ({
  label: getProjectServiceLabel(service),
  href: getProjectServiceHref(service.data.slug, lang),
}));

let pageTitle = '';
let pageDescription = '';
let pageContent:
  | {
      kind: 'project';
      project: ProjectEntry;
      shortTitle: string;
      titleDisplay: string;
      featuredImage: ProjectEntry['data']['featuredImage'];
      featuredImageAlt: string;
      gallery: LocalizedProjectGalleryRow[];
      services: ProjectServiceSlug[];
      projectTypes: string[];
      externalUrl?: string;
      descriptionContent: string;
      breadcrumbItems: { label: string; href?: string }[];
    }
  | {
      kind: 'service';
      serviceSlug: ProjectServiceSlug;
      service: ProjectService;
      projects: typeof allLocalizedProjects;
      breadcrumbItems: { label: string; href?: string }[];
    };

if (props.kind === 'project') {
  const localizedProject = localizeProject(props.project, lang);
  const descriptionContent = await getLocalizedProjectDescription(props.project.data.slug, lang);

  pageTitle = localizedProject.fullTitle;
  pageDescription = localizedProject.seoDescription;
  pageContent = {
    kind: 'project',
    project: props.project,
    shortTitle: localizedProject.shortTitle,
    titleDisplay: localizedProject.titleDisplay,
    featuredImage: localizedProject.featuredImage,
    featuredImageAlt: localizedProject.featuredImageAlt,
    gallery: localizedProject.gallery,
    services: getProjectServices(props.project),
    projectTypes: localizedProject.projectTypes,
    externalUrl: localizedProject.externalUrl,
    descriptionContent,
    breadcrumbItems: [
      { label: copy[lang].breadcrumbHome, href: `/${lang}` },
      { label: copy[lang].breadcrumbProjects, href: `/${lang}/projets` },
      { label: localizedProject.shortTitle },
    ],
  };
} else {
  const service = props.service;
  const projects = allLocalizedProjects.filter(
    (project) => !project.inProgress && project.services.includes(service.data.slug),
  );

  pageTitle = getProjectServiceTitle(service, lang);
  pageDescription = getProjectServiceDescription(service);
  pageContent = {
    kind: 'service',
    serviceSlug: service.data.slug,
    service,
    projects,
    breadcrumbItems: [
      { label: copy[lang].breadcrumbHome, href: `/${lang}` },
      { label: copy[lang].breadcrumbProjects, href: `/${lang}/projets` },
      { label: getProjectServiceLabel(service) },
    ],
  };
}
---

<Layout
  lang={lang}
  title={pageTitle}
  description={pageDescription}
  variant={pageContent.kind === 'project' ? 'dark' : 'light'}
  headerVariant={pageContent.kind === 'project' ? 'dark' : 'light'}
  showContainerLines={pageContent.kind !== 'service'}
>
  {pageContent.kind === 'project' ? (
    <article id="page-content" class="project-page">
      <header class="project-hero">
        <div class="relative isolate h-[310px] mt-24 flex flex-col items-center justify-center">
          <ProjectsShapeBand class="project-shape top-0 h-full text-lines-dark" />
          <Breadcrumbs
            items={pageContent.breadcrumbItems}
            class="absolute top-0 mt-16"
            variant="dark"
            ariaLabel={lang === 'fr' ? 'Fil d’Ariane' : 'Breadcrumb'}
          />
          <div class="relative z-10 flex items-center justify-center gap-8">
            <svg width="6" height="30" viewBox="0 0 6 30" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M4.39106 0H6C3.62011 4.16285 1.84358 8.70413 1.84358 15.0688C1.84358 21.2959 3.62011 25.8372 6 30H4.39106C2.07821 26.5252 0 21.2959 0 15.0688C0 8.63532 2.07821 3.47477 4.39106 0Z" fill="white"/>
            </svg>
            <h1 class="font-display text-[2rem] uppercase mt-1">{pageContent.shortTitle}</h1>
            <svg width="6" height="29" viewBox="0 0 6 29" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1.60894 28.7998L-2.86102e-06 28.7998C2.37989 24.8035 4.15642 20.4438 4.15643 14.3337C4.15643 8.35576 2.37989 3.99612 -2.38339e-07 -0.000210312L1.60894 -0.000210177C3.92179 3.33557 6 8.35576 6 14.3337C6 20.5099 3.92179 25.464 1.60894 28.7998Z" fill="white"/>
            </svg>
          </div>
        </div>

        {pageContent.services.length > 0 && (
          <nav aria-label={copy[lang].projectServices}>
            <ul>
              {pageContent.services.map((serviceSlug) => (
                <li>
                  <a href={getProjectServiceHref(serviceSlug, lang)}>
                    {getProjectServiceLabel(projectServices.find((service) => service.data.slug === serviceSlug)!)}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        )}

        {pageContent.projectTypes.length > 0 && (
          <ul aria-label={copy[lang].projectTypes}>
            {pageContent.projectTypes.map((type: string) => <li>{type}</li>)}
          </ul>
        )}

        {pageContent.externalUrl && (
          <a href={pageContent.externalUrl} target="_blank" rel="noopener noreferrer">
            {copy[lang].externalUrl}
          </a>
        )}
      </header>

      <main class="project-content">
        <Image src={pageContent.featuredImage} alt={pageContent.featuredImageAlt} />

        {pageContent.descriptionContent && (
          <section class="project-description">{pageContent.descriptionContent}</section>
        )}

        {pageContent.gallery.length > 0 && (
          <section class="project-gallery" aria-label={copy[lang].gallery}>
            {pageContent.gallery.map((row: LocalizedProjectGalleryRow) => (
              <div class:list={['project-gallery-row', `project-gallery-row--${row.layout}`]}>
                <Image src={row.image1} alt={row.alt1} />
                {row.image2 && <Image src={row.image2} alt={row.alt2 || row.alt1} />}
              </div>
            ))}
          </section>
        )}
      </main>
    </article>
  ) : (
    <ProjectsListingPage
      projects={pageContent.projects}
      lang={lang}
      intro={getProjectServiceIntro(pageContent.service)}
      allLabel={copy[lang].allProjects}
      filters={serviceFilters}
    />
  )}

  <Footer lang={lang} variant={pageContent.kind === 'project' ? 'dark' : 'light'} hideOverflow={false} />
</Layout>
