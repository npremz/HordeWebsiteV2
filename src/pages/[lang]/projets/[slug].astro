---
import { Image } from 'astro:assets';
import Layout from '../../../layouts/Layout.astro';
import Footer from '../../../components/Footer.astro';
import HeroStructure from '../../../components/blog/HeroStructure.astro';
import ProjectsListingPage from '../../../components/projects/ProjectsListingPage.astro';
import { SUPPORTED_LOCALES, type Locale, useTranslations } from '../../../i18n';
import {
  type LocalizedProjectGalleryRow,
  type ProjectEntry,
  getLocalizedProjectDescriptionParagraphs,
  getLocalizedProjects,
  getProjects,
  localizeProject,
} from '../../../lib/content/projects';
import {
  type ProjectServiceSlug,
  type ProjectService,
  getProjectServiceDescription,
  getProjectServiceEntries,
  getProjectServiceHref,
  getProjectServiceIntro,
  getLocalizedProjectServiceLabel,
  getProjectServiceTitle,
  getProjectServices,
} from '../../../lib/projectServices';

export const prerender = true;

type ProjectPageProps = {
  kind: 'project';
  project: ProjectEntry;
  lang: Locale;
};

type ServicePageProps = {
  kind: 'service';
  service: ProjectService;
  lang: Locale;
};

export async function getStaticPaths() {
  const projects = await getProjects();
  const services = await getProjectServiceEntries();
  const projectSlugs = new Set(projects.map((project) => project.data.slug));

  const projectPaths = SUPPORTED_LOCALES.flatMap((lang) =>
    projects
      .filter((project) => !project.data.inProgress)
      .map((project) => ({
        params: { lang, slug: project.data.slug },
        props: { kind: 'project', project, lang },
      })),
  );

  const servicePaths = SUPPORTED_LOCALES.flatMap((lang) =>
    services
      .filter((service) => !projectSlugs.has(service.data.slug))
      .map((service) => ({
        params: { lang, slug: service.data.slug },
        props: { kind: 'service', service, lang },
      })),
  );

  return [...projectPaths, ...servicePaths];
}

const props = Astro.props as ProjectPageProps | ServicePageProps;
const { lang } = props;
const t = useTranslations(lang);
const projectCopy = t.projectSingle;
const projectFilterLabels: Record<string, { fr: string; en: string }> = {
  'creation-ecommerce': { fr: 'E-commerce', en: 'E-commerce' },
  'optimisation-site-web': { fr: 'Optimisation', en: 'Optimization' },
  'creation-landing-page': { fr: 'Landing Page', en: 'Landing Page' },
  'creation-mvp-saas': { fr: 'Saas Mvp', en: 'Saas Mvp' },
  'refonte-site-web': { fr: 'Refonte', en: 'Redesign' },
};

const allLocalizedProjects = await getLocalizedProjects(lang);
const singleWorkProjectSlugs = ['e-putch', 'merly'];
const singleWorkProjects = singleWorkProjectSlugs
  .map((slug) => allLocalizedProjects.find((project) => project.slug === slug))
  .filter((project): project is (typeof allLocalizedProjects)[number] => Boolean(project));
const singleWorkCount = `(${String(singleWorkProjects.length).padStart(2, '0')})`;
const projectServices = await getProjectServiceEntries();
const serviceFilterProjects = allLocalizedProjects.filter((project) => !project.inProgress);
const serviceFilters = projectServices
  .filter((service) =>
    serviceFilterProjects.some((project) => project.services.includes(service.data.slug)),
  )
  .map((service) => ({
    label: projectFilterLabels[service.data.slug]?.[lang] || getLocalizedProjectServiceLabel(service, lang),
    href: getProjectServiceHref(service.data.slug, lang),
  }));

function getDisplayTitle(project: (typeof allLocalizedProjects)[number]): string {
  return project.shortTitle.replace(/-/g, '').toUpperCase();
}

let pageTitle = '';
let pageDescription = '';
let pageContent:
  | {
      kind: 'project';
      project: ProjectEntry;
      shortTitle: string;
      titleDisplay: string;
      featuredImage: ProjectEntry['data']['featuredImage'];
      featuredImageAlt: string;
      gallery: LocalizedProjectGalleryRow[];
      services: ProjectServiceSlug[];
      projectTypes: string[];
      externalUrl?: string;
      descriptionParagraphs: string[];
      breadcrumbItems: { label: string; href?: string }[];
    }
  | {
      kind: 'service';
      serviceSlug: ProjectServiceSlug;
      service: ProjectService;
      projects: typeof allLocalizedProjects;
      breadcrumbItems: { label: string; href?: string }[];
    };

if (props.kind === 'project') {
  const localizedProject = localizeProject(props.project, lang);
  const descriptionParagraphs = await getLocalizedProjectDescriptionParagraphs(props.project.data.slug, lang);

  pageTitle = localizedProject.fullTitle;
  pageDescription = localizedProject.seoDescription;
  pageContent = {
    kind: 'project',
    project: props.project,
    shortTitle: localizedProject.shortTitle,
    titleDisplay: localizedProject.titleDisplay,
    featuredImage: localizedProject.featuredImage,
    featuredImageAlt: localizedProject.featuredImageAlt,
    gallery: localizedProject.gallery,
    services: getProjectServices(props.project),
    projectTypes: localizedProject.projectTypes,
    externalUrl: localizedProject.externalUrl,
    descriptionParagraphs,
    breadcrumbItems: [
      { label: projectCopy.breadcrumbHome, href: `/${lang}` },
      { label: projectCopy.breadcrumbProjects, href: `/${lang}/projets` },
      { label: localizedProject.shortTitle },
    ],
  };
} else {
  const service = props.service;
  const projects = allLocalizedProjects.filter(
    (project) => !project.inProgress && project.services.includes(service.data.slug),
  );

  pageTitle = getProjectServiceTitle(service, lang);
  pageDescription = getProjectServiceDescription(service, lang);
  pageContent = {
    kind: 'service',
    serviceSlug: service.data.slug,
    service,
    projects,
    breadcrumbItems: [
      { label: projectCopy.breadcrumbHome, href: `/${lang}` },
      { label: projectCopy.breadcrumbProjects, href: `/${lang}/projets` },
      { label: getLocalizedProjectServiceLabel(service, lang) },
    ],
  };
}
---

<Layout
  lang={lang}
  title={pageTitle}
  description={pageDescription}
  variant={pageContent.kind === 'project' ? 'dark' : 'light'}
  headerVariant={pageContent.kind === 'project' ? 'dark' : 'light'}
  showContainerLines={pageContent.kind !== 'service'}
>
  {pageContent.kind === 'project' ? (
    <article id="page-content" class="project-page relative">
      <HeroStructure
        background="dark"
        showHorizontalLine={false}
        showVerticalLine={true}
        showObliqueLines={true}
        ariaLabelledby="project-intro"
        breadcrumbItems={pageContent.breadcrumbItems}
        breadcrumbAriaLabel={projectCopy.breadcrumbAriaLabel}
        spacingClass="pt-16 pb-24 sm:pt-32 sm:pb-28 lg:pt-40 lg:pb-32 2xl:pb-40"
        contentClass="h-[426px] justify-start lg:h-[490px]"
      >
        <div class="project-hero mx-auto flex h-[426px] w-full items-center justify-center lg:h-[490px]">
          <div class="relative isolate flex flex-col items-center justify-center ">
            <div class="relative z-10 flex items-center justify-center gap-8">
              <svg class="h-8 sm:h-10" viewBox="0 0 6 30" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M4.39106 0H6C3.62011 4.16285 1.84358 8.70413 1.84358 15.0688C1.84358 21.2959 3.62011 25.8372 6 30H4.39106C2.07821 26.5252 0 21.2959 0 15.0688C0 8.63532 2.07821 3.47477 4.39106 0Z" fill="white"/>
              </svg>
              <h1 id="project-intro" class="font-display mt-1 text-[50px] uppercase">{pageContent.shortTitle}</h1>
              <svg class="h-8 sm:h-10" viewBox="0 0 6 29" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1.60894 28.7998L-2.86102e-06 28.7998C2.37989 24.8035 4.15642 20.4438 4.15643 14.3337C4.15643 8.35576 2.37989 3.99612 -2.38339e-07 -0.000210312L1.60894 -0.000210177C3.92179 3.33557 6 8.35576 6 14.3337C6 20.5099 3.92179 25.464 1.60894 28.7998Z" fill="white"/>
              </svg>
            </div>
          </div>
        </div>
      </HeroStructure>
      <div class="relative z-1 -mt-54 sm:-mt-66 md:-mt-85 lg:-mt-97 2xl:-mt-106">
        {pageContent.externalUrl && (
          <div class="w-full flex text-[1.125rem] lg:text-[1.375rem] justify-between ">
            <span>2025©</span>
            <a href={pageContent.externalUrl} target="_blank" rel="noopener noreferrer" class="underline!">
              {projectCopy.externalUrl} (↗)
            </a>
          </div>
        )}
        <div class="md:flex md:gap-10 mt-10 sm:mt-24 md:mt-40 lg:mt-36 2xl:mt-48">
          {pageContent.services.length > 0 && (
            <nav aria-label={projectCopy.projectServices} class="md:mt-0 text-[1.25rem] md:flex md:flex-col md:justify-between md:w-1/2">
              <div class="sm:flex sm:gap-8">
                <p>{projectCopy.serviceFilterLabel}</p>
                <ul class="mt-5 sm:mt-0 sm:flex sm:gap-4">
                  {pageContent.services.map((serviceSlug) => (
                    <li>
                      <a href={getProjectServiceHref(serviceSlug, lang)} class="underline! underline-offset-2">
                        {getLocalizedProjectServiceLabel(projectServices.find((service) => service.data.slug === serviceSlug)!, lang)}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
              <span class="hidden md:block mt-10 sm:mt-16 text-[1.125rem]">(↓)</span>
            </nav>
          )}

          <div class="hidden md:flex md:w-1/2 justify-end">
            {pageContent.descriptionParagraphs.length > 0 && (
              <section class="project-description flex flex-col gap-10 sm:gap-16 md:gap-8 text-[1.125rem] sm:max-w-[500px]">
                {pageContent.descriptionParagraphs.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}
              </section>
            )}
          </div>
        </div>
      </div>
      <main class="project-content mt-10 sm:mt-16 md:mt-50 lg:max-w-[1000px] lg:mx-auto">

        <div class="md:hidden">
          {pageContent.descriptionParagraphs.length > 0 && (
            <section class="project-description flex flex-col gap-10 sm:gap-16 text-[1.125rem] sm:max-w-[500px]">
              {pageContent.descriptionParagraphs.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </section>
          )}
        </div>

        <span class="block md:hidden mt-10 sm:mt-16 text-[1.125rem]">(↓)</span>

        {pageContent.gallery.length > 0 && (
          <section class="project-gallery bg-black mt-16 sm:mt-32 flex flex-col gap-2.5 sm:gap-5" aria-label={projectCopy.gallery}>
            {pageContent.gallery.map((row: LocalizedProjectGalleryRow) => (
              <div
                class:list={[
                  'project-gallery-row gap-2.5 sm:gap-5',
                  row.layout === 'half' && row.image2 ? 'grid grid-cols-2' : 'grid grid-cols-1',
                  `project-gallery-row--${row.layout}`,
                ]}
              >
                <Image src={row.image1} alt={row.alt1} class="w-full" />
                {row.image2 && <Image src={row.image2} alt={row.alt2 || row.alt1} class="w-full" />}
              </div>
            ))}
          </section>
        )}

        {singleWorkProjects.length > 0 && (
          <nav class="project-work-nav mt-16 sm:mt-24 text-button-white" aria-label={projectCopy.allWork}>
            <a
              href={`/${lang}/projets`}
              class="project-work-row grid min-h-[78px] place-items-center border-b border-lines-dark py-6 sm:py-10 lg:py-12 text-center font-display text-[2.25rem] sm:text-[3rem] uppercase leading-none tracking-normal sm:min-h-[108px] md:min-h-[120px] lg:text-[5rem]"
            >
              <span>
                {projectCopy.allWork}
                <span class="ml-1 text-[1.125rem] font-sans leading-none">
                  {singleWorkCount}
                </span>
              </span>
            </a>

            <ol>
              {singleWorkProjects.map((project) => {
                const href = project.inProgress ? undefined : `/${lang}/projets/${project.slug}`;
                const RowTag = project.inProgress ? 'div' : 'a';

                return (
                  <li>
                    <RowTag
                      href={href}
                      class:list={[
                        'project-work-row grid min-h-[78px] place-items-center py-6 text-center sm:min-h-[108px] md:min-h-[120px] sm:py-10 lg:py-12',
                        project === singleWorkProjects.at(-1) ? '' : 'border-b border-lines-dark',
                      ]}
                      title={project.shortTitle}
                    >
                      <span class="font-display text-[2.25rem] uppercase leading-none tracking-normal sm:text-center sm:text-[3rem] lg:text-[5rem]">
                        {getDisplayTitle(project)}
                      </span>
                    </RowTag>
                  </li>
                );
              })}
            </ol>
          </nav>
        )}
      </main>

      <style>
        .project-hero,
        .project-content {
          position: relative;
          z-index: 1;
        }

        .project-work-row {
          position: relative;
          isolation: isolate;
          left: 50%;
          width: min(1300px, 100vw);
          transform: translateX(-50%);
        }

        .project-work-row::before {
          content: "";
          position: absolute;
          inset: 0;
          z-index: -1;
          background: var(--color-bg-light);
          transform: scaleY(0);
          transform-origin: bottom center;
          transition: transform 0.28s ease-out;
        }

        @media (hover: hover) {
          a.project-work-row:hover {
            color: var(--color-black);
          }

          a.project-work-row:hover::before {
            transform: scaleY(1);
          }
        }
      </style>
    </article>
  ) : (
    <ProjectsListingPage
      projects={pageContent.projects}
      lang={lang}
      intro={getProjectServiceIntro(pageContent.service, lang)}
      allLabel={projectCopy.allProjects}
      filters={serviceFilters}
    />
  )}

  <Footer lang={lang} variant={pageContent.kind === 'project' ? 'dark' : 'light'} hideOverflow={false} />
</Layout>
