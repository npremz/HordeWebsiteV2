---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import ProjectsShapeBand from '../../components/projects/ProjectsShapeBand.astro';
import Breadcrumbs from '../../components/ui/navigation/Breadcrumbs.astro';
import { SUPPORTED_LOCALES, type Locale, useTranslations } from '../../i18n';
import { getLocalizedCategories, getLocalizedPosts } from '../../lib/content/blog';
import { formatHeadingHtml } from '../../utils/heading-html';

export const prerender = true;

export function getStaticPaths() {
  return SUPPORTED_LOCALES.map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);
const [categories, posts] = await Promise.all([
  getLocalizedCategories(lang),
  getLocalizedPosts(lang),
]);
const allLabel = lang === 'fr' ? 'Tous' : 'All';

const breadcrumbItems = [
  { label: lang === 'fr' ? 'Accueil' : 'Home', href: `/${lang}` },
  { label: 'Blog' },
];

function formatDate(date: Date, locale: Locale): string {
  return new Intl.DateTimeFormat(locale === 'fr' ? 'fr-BE' : 'en-US', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
  }).format(date);
}
---

<Layout
  lang={lang}
  title={t.blogPage.title}
  description={t.blogPage.description}
  variant="light"
  headerVariant="dark"
  showContainerLines={false}
>
  <article id="page-content" class="blog-listing-page">
    <header class="blog-hero relative isolate mt-48 flex min-h-[360px] flex-col items-center justify-center py-0 text-bg-light sm:min-h-[640px] sm:py-40">
      <ProjectsShapeBand class="top-0 h-full text-lines-dark" />

      <Breadcrumbs
        items={breadcrumbItems}
        class="absolute -top-10"
        variant="dark"
        ariaLabel={lang === 'fr' ? 'Fil d’Ariane' : 'Breadcrumb'}
      />

      <div class="relative h-full z-10 flex w-full flex-col text-center px-6">
        <svg class="h-8 absolute left-0 top-1" viewBox="0 0 6 30" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M4.39106 0H6C3.62011 4.16285 1.84358 8.70413 1.84358 15.0688C1.84358 21.2959 3.62011 25.8372 6 30H4.39106C2.07821 26.5252 0 21.2959 0 15.0688C0 8.63532 2.07821 3.47477 4.39106 0Z" fill="white"/>
        </svg>
        <h1 class="font-sans text-[1.5rem] sm:text-[2rem] md:text-[2.5rem] text-left sm:max-w-[500px] md:max-w-[600px]" set:html={formatHeadingHtml(t.blogPage.heading)} />
        <svg class="h-8 absolute right-0 bottom-1" viewBox="0 0 6 30" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1.60894 30L-2.86102e-06 30C2.37989 25.8372 4.15642 21.2959 4.15643 14.9312C4.15643 8.70413 2.37989 4.16284 -1.29062e-07 -5.03556e-07L1.60894 -3.68524e-07C3.92179 3.47477 6 8.70413 6 14.9312C6 21.3647 3.92179 26.5252 1.60894 30Z" fill="white"/>
        </svg>
      </div>
      

    </header>

    <nav class="blog-filter-wrap mt-40 flex items-start justify-between text-[1.125rem] leading-none sm:text-[1.25rem] md:mx-auto md:max-w-[1000px]" aria-label={lang === 'fr' ? 'Catégories principales' : 'Main categories'}>
      <details class="blog-filter relative w-fit">
        <summary
          class="cursor-pointer list-none underline decoration-[1px] underline-offset-2 transition-opacity duration-200 hover:opacity-65"
        >
          {allLabel} (↓)
        </summary>
        <div
          class="filter-panel absolute left-0 top-full z-20 mt-5 hidden w-max max-w-[calc(100vw-2rem)] flex-wrap gap-5 bg-bg-light px-6 py-4 text-[1rem] text-black shadow-none sm:max-w-none"
        >
          <a href={`/${lang}/blog`} class="whitespace-nowrap leading-none transition-opacity duration-200 hover:opacity-65" aria-current="page">
            {allLabel}
          </a>
          {
            categories.map((category) => (
              <a href={`/${lang}/blog/category/${category.slug}`} class="whitespace-nowrap leading-none transition-opacity duration-200 hover:opacity-65">
                {category.name}
              </a>
            ))
          }
        </div>
      </details>
    </nav>

    <main class="blog-listing-content mx-auto w-full max-w-[1300px] bg-bg py-16 text-black sm:py-24">
      <ol class="blog-post-list grid gap-12 sm:gap-16 lg:max-w-[1000px] lg:mx-auto">
        {posts.map((post) => (
          <li class="blog-post-item border-b border-lines">
            <article class="blog-post-card grid gap-6 sm:grid-cols-[minmax(180px,200px)_1fr] md:grid-cols-[minmax(180px,276px)_1fr] sm:gap-10 sm:pb-16">
              <a href={`/${lang}/blog/${post.slug}`} class="blog-post-image-link block" aria-label={post.title}>
                <Image
                  src={post.listingImage}
                  alt={post.listingImageAlt}
                  class="aspect-square w-full object-cover"
                  widths={[320, 480, 640]}
                  sizes="(max-width: 640px) 100vw, 320px"
                  loading="lazy"
                  decoding="async"
                  format="webp"
                />
              </a>

              <div class="blog-post-copy flex flex-col sm:justify-between">
                <div>
                  <h2 class="blog-post-title font-sans text-[1.5rem] md:max-w-[500px] leading-tight">
                    <a href={`/${lang}/blog/${post.slug}`}>
                      {post.title}
                    </a>
                  </h2>
                  <div class="flex items-center gap-2 mt-5">
                    <p class="blog-post-category text-[1.125rem] leading-none">
                      {post.categoryName}
                    </p>
                    <span>-</span>
                    <p class="blog-post-reading-time text-[1.125rem] leading-none">
                      {post.readingTime} {lang === 'fr' ? 'min de lecture' : 'min read'}
                    </p>
                  </div>
                </div>

                <div class="flex flex-col sm:items-center sm:flex-row-reverse sm:justify-between sm:mt-5">
                  <p class="blog-post-meta text-[1.125rem] leading-none mt-5 sm:mt-0">
                    {lang === 'fr' ? 'Par' : 'By'} {post.authorName} - {formatDate(new Date(post.publishedDate), lang)}
                  </p>

                  <a href={`/${lang}/blog/${post.slug}`} class="blog-post-link w-fit leading-none underline! decoration-[1px] underline-offset-2 mt-5 sm:mt-0">
                    {lang === 'fr' ? 'Lire l’article' : 'Read article'} →
                  </a>
                </div>
              </div>
            </article>
          </li>
        ))}
      </ol>
    </main>
  </article>

  <Footer lang={lang} variant="light" hideOverflow={false} />
</Layout>

<style>
  .blog-hero::before {
    content: "";
    position: absolute;
    top: -12rem;
    bottom: -6rem;
    left: 50%;
    z-index: -20;
    width: 100vw;
    transform: translateX(-50%);
    background: var(--color-black);
  }

  .blog-filter summary::-webkit-details-marker {
    display: none;
  }

  .blog-filter[open] .filter-panel {
    display: flex;
  }
</style>
