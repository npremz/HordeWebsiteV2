---
import Layout from '../../../layouts/Layout.astro';
import Footer from '../../../components/Footer.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { SUPPORTED_LOCALES, type Locale } from '../../../i18n';

export const prerender = true;

export async function getStaticPaths() {
  const authors = await getCollection('authors');

  return SUPPORTED_LOCALES.flatMap((lang) =>
    authors.map((author) => ({
      params: { lang, slug: author.data.slug },
      props: { author, lang },
    }))
  );
}

const { author, lang } = Astro.props as { author: any; lang: Locale };

const name = author.data.name;
const role = lang === 'fr' ? author.data.role_fr : author.data.role_en;
const bio = lang === 'fr' ? author.data.bio_fr : author.data.bio_en;
const avatar = author.data.avatar;
const social = author.data.social || {};

const allPosts = await getCollection('posts');
const authoredPosts = allPosts
  .filter((post) => !post.data.draft && post.data.author === author.data.slug)
  .sort((a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime())
  .map((post) => ({
    slug: lang === 'fr' ? post.data.slug_fr : post.data.slug,
    title: lang === 'fr' ? post.data.title_fr : post.data.title_en,
    excerpt: lang === 'fr' ? post.data.excerpt_fr : post.data.excerpt_en,
    publishedDate: post.data.publishedDate,
  }));

const siteUrl = (Astro.site?.toString() || 'https://hordeagence.com').replace(/\/$/, '');
const authorUrl = `${siteUrl}/${lang}/authors/${author.data.slug}`;
const title = `${name} | Horde Agence`;
const description = bio || role || title;
const sameAs = [
  social.twitter ? `https://twitter.com/${social.twitter}` : null,
  social.linkedin || null,
  social.github ? `https://github.com/${social.github}` : null,
].filter(Boolean);

const schemaOrg = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': `${authorUrl}#person`,
      name,
      url: authorUrl,
      image: `${siteUrl}${avatar.src}`,
      jobTitle: role,
      description: bio,
      sameAs,
      worksFor: {
        '@type': 'Organization',
        '@id': `${siteUrl}#organization`,
        name: 'Horde Agence',
      },
    },
    {
      '@type': 'ProfilePage',
      '@id': `${authorUrl}#webpage`,
      url: authorUrl,
      name: title,
      description,
      mainEntity: {
        '@id': `${authorUrl}#person`,
      },
      inLanguage: lang === 'fr' ? 'fr-BE' : 'en-US',
    },
  ],
};

function formatDate(date: Date, locale: string): string {
  return new Intl.DateTimeFormat(locale === 'fr' ? 'fr-BE' : 'en-US', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(new Date(date));
}
---

<Layout lang={lang} title={title} description={description} canonical={authorUrl}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />

  <div class="fixed inset-0 bg-bg-light -z-10" aria-hidden="true"></div>
  <article id="page-content" class="relative z-10 pt-50 sm:pt-78">
    <header class="pb-10 sm:pb-16 border-b border-lines">
      <div class="flex flex-col gap-8 md:flex-row md:items-end md:justify-between">
        <div class="max-w-3xl">
          <p class="section-label mb-4">{lang === 'fr' ? 'Auteur' : 'Author'}</p>
          <h1 class="font-display text-[2rem] md:text-[2.5rem] lg:text-[3rem] leading-[1.1] uppercase">{name}</h1>
          {role && <p class="mt-6 text-[1.375rem]">{role}</p>}
          {bio && <p class="mt-8 text-[1.375rem] leading-relaxed max-w-2xl">{bio}</p>}
        </div>
        {avatar && (
          <Image
            src={avatar}
            alt={name}
            class="w-32 h-32 md:w-40 md:h-40 object-cover aspect-square"
            widths={[128, 160, 240]}
            sizes="160px"
            loading="eager"
            decoding="async"
          />
        )}
      </div>

      {sameAs.length > 0 && (
        <div class="mt-8 flex flex-wrap gap-4 section-label">
          {social.twitter && <a href={`https://twitter.com/${social.twitter}`} target="_blank" rel="noopener noreferrer" title="Twitter">Twitter</a>}
          {social.linkedin && <a href={social.linkedin} target="_blank" rel="noopener noreferrer" title="LinkedIn">LinkedIn</a>}
          {social.github && <a href={`https://github.com/${social.github}`} target="_blank" rel="noopener noreferrer" title="GitHub">GitHub</a>}
        </div>
      )}
    </header>

    <section class="mt-10 sm:mt-16">
      <h2 class="section-label mb-8">{lang === 'fr' ? 'Articles signés' : 'Articles by this author'}</h2>
      {authoredPosts.length > 0 ? (
        <div class="border-t border-lines">
          {authoredPosts.map((post) => (
            <a href={`/${lang}/blog/${post.slug}`} class="block py-8 border-b border-lines" title={post.title}>
              <p class="text-[1.375rem] mb-3">{post.title}</p>
              <p class="section-label mb-4">
                <time datetime={post.publishedDate.toISOString()}>{formatDate(post.publishedDate, lang)}</time>
              </p>
              <p class="text-black/70 max-w-3xl">{post.excerpt}</p>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-black/60">{lang === 'fr' ? 'Aucun article publié pour le moment.' : 'No published articles yet.'}</p>
      )}
    </section>
  </article>

  <Footer lang={lang} hideOverflow={false} />
</Layout>
