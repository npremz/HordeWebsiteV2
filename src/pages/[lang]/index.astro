---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/homepage/Hero.astro";
import About from "../../components/homepage/About.astro";
import Projects from "../../components/homepage/Projects.astro";
import Demarche from "../../components/homepage/Demarche.astro";
import Services from "../../components/homepage/Services.astro";
import Us from "../../components/homepage/Us.astro";
import PixelTransitionCanvas from "../../components/ui/effects/PixelTransitionCanvas.astro";
import Footer from "../../components/Footer.astro";
import { SUPPORTED_LOCALES, type Locale } from "../../i18n";
import { getSiteSettings } from "../../lib/site-data";

export const prerender = true;

export function getStaticPaths() {
  return SUPPORTED_LOCALES.map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Locale };
const siteSettings = await getSiteSettings(lang);

const title = siteSettings.homepageTitle || "Horde";
const description =
  siteSettings.defaultDescription ||
  (lang === "fr"
    ? "Agence web spécialisée en performance et UX."
    : "Web agency specialized in performance and UX.");
---

<Layout
  lang={lang}
  title={title}
  description={description}
  siteNameAsPrefix={true}
>
  <PixelTransitionCanvas
    color="rgb(22, 25, 27)"
    triggerDistance={500}
    topOffset={600}
    targetId="services"
    stopTargetId="demarche"
    stopWhenTargetCoversViewport
    class="z-10"
  />
  <Hero lang={lang} />
  <About lang={lang} />
  <Projects lang={lang} />
  <div id="services-section" class="relative pt-25 z-20">
    <Services lang={lang} />
  </div>
  <div class="relative z-20 full-width-white-bg">
    <Demarche lang={lang} />
  </div>
  <Us lang={lang} />
  <Footer slot="footer" lang={lang} variant="light" innerBg />
</Layout>
