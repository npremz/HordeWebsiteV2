---
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import HeroStructure from "../../components/blog/HeroStructure.astro";
import { SUPPORTED_LOCALES, type Locale, useTranslations } from "../../i18n";
import { getLocalizedCategories, getLocalizedPosts } from "../../lib/content/blog";
import { formatHeadingHtml } from "../../utils/heading-html";

export const prerender = true;

export function getStaticPaths() {
  return SUPPORTED_LOCALES.map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);

const [categories, posts] = await Promise.all([
  getLocalizedCategories(lang),
  getLocalizedPosts(lang),
]);

const allLabel = lang === "fr" ? "Tous" : "All";
const filterListLabel = lang === "fr" ? "Filtres" : "Filters";
const categoriesAriaLabel = lang === "fr" ? "Catégories principales" : "Main categories";
const breadcrumbAriaLabel = lang === "fr" ? "Fil d’Ariane" : "Breadcrumb";
const breadcrumbItems = [
  { label: lang === "fr" ? "Accueil" : "Home", href: `/${lang}` },
  { label: "Blog" },
];

const usedCategorySlugs = new Set(posts.map((post) => post.categorySlug));
const filterLinks = [
  { href: `/${lang}/blog`, label: allLabel, current: true },
  ...categories
    .filter((category) => usedCategorySlugs.has(category.slug))
    .map((category) => ({
      href: `/${lang}/blog/category/${category.slug}`,
      label: category.name,
      current: false,
    })),
];
---

<Layout
  lang={lang}
  title="Blog hero preview"
  description="Preview page for the reusable blog hero structure."
  variant="light"
  headerVariant="dark"
  showContainerLines={false}
>
  <article id="page-content" class="text-black">
    <HeroStructure
      background="dark"
      showHorizontalLine
      showVerticalLine
      showObliqueLines
      ariaLabelledby="blog-intro"
      breadcrumbItems={breadcrumbItems}
      breadcrumbAriaLabel={breadcrumbAriaLabel}
    >
      <div class="flex w-full flex-col sm:flex-row sm:justify-between">
        <div class="relative z-10 flex max-w-[760px] flex-col gap-4 sm:gap-8 sm:pr-4 md:pr-16 lg:w-1/2">
          <h1
            id="blog-intro"
            class="text-[1.5rem] leading-tight sm:text-[2rem] md:text-[2.5rem]"
            set:html={formatHeadingHtml(t.blogPage.heading)}
          />
        </div>

        <svg
          class="relative z-10 mt-2 self-end text-current sm:self-start"
          width="20"
          height="20"
          viewBox="0 0 20 20"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <rect
            width="7"
            height="20"
            transform="matrix(0.707107 0.707107 0.707107 -0.707107 0 14.1406)"
            fill="currentColor"
          />
        </svg>
      </div>

      <nav
        class="relative z-10 mt-4 flex flex-col sm:mt-16 sm:w-full sm:flex-row sm:justify-between lg:mt-0 lg:w-1/2 lg:self-end lg:justify-around lg:gap-20"
        aria-label={categoriesAriaLabel}
      >
        <p class="text-[1.375rem] sm:text-[1.5rem]">{filterListLabel}:</p>

        <ul class="relative mt-8 flex list-[square] flex-col gap-2.5 pl-5 pr-10 text-[1.25rem] sm:mt-0 sm:pr-24">
          {
            filterLinks.map((filter) => (
              <li>
                <a
                  href={filter.href}
                  class="transition-opacity duration-200 hover:opacity-65"
                  aria-current={filter.current ? "page" : undefined}
                >
                  {filter.label}
                </a>
              </li>
            ))
          }
          <svg
            class="absolute bottom-0 right-0 z-10 text-current"
            width="8"
            height="35"
            viewBox="0 0 8 35"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path
              d="M1.95527 35L-4.1008e-05 35C2.89218 30.1433 5.05117 24.8452 5.05117 17.4197C5.05117 10.1548 2.89219 4.85665 -3.78207e-05 -6.1196e-07L1.95527 -4.47859e-07C4.76602 4.0539 7.29163 10.1548 7.29163 17.4197C7.29163 24.9255 4.76602 30.9461 1.95527 35Z"
              fill="currentColor"
            />
          </svg>
        </ul>
      </nav>
    </HeroStructure>
  </article>

  <Footer lang={lang} variant="light" hideOverflow={false} />
</Layout>
