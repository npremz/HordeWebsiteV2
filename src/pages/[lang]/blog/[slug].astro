---
import Layout from '../../../layouts/Layout.astro';
import Footer from '../../../components/Footer.astro';
import HeroStructure from '../../../components/blog/HeroStructure.astro';
import { Image } from 'astro:assets';
import { SUPPORTED_LOCALES, type Locale, useTranslations } from '../../../i18n';
import {
	getBlogIndexHref,
	getBlogPostHref,
	getBlogTagHref,
	type PostEntry,
	getLocalizedPostContent,
	getLocalizedPosts,
	getPosts,
} from '../../../lib/content/blog';

export const prerender = true;

export async function getStaticPaths() {
	const posts = await getPosts();

	return SUPPORTED_LOCALES.flatMap((lang) =>
		posts
			.filter((post) => !post.data.draft)
			.map((post) => ({
				params: { lang, slug: lang === 'fr' ? post.data.slug_fr : post.data.slug },
				props: { post, lang },
			}))
	);
}

const { post, lang } = Astro.props as { post: PostEntry; lang: Locale };
const t = useTranslations(lang);
const allLocalizedPosts = await getLocalizedPosts(lang);
const currentPost = allLocalizedPosts.find((entry) => entry.entry.id === post.id);

if (!currentPost) {
	throw new Error(`Missing localized blog post for ${post.id} (${lang})`);
}

const title = currentPost.title;
const excerpt = currentPost.excerpt;
const seoDescription = currentPost.seoDescription;
const featuredImageAlt = currentPost.featuredImageAlt;
const authorName = currentPost.authorName;
const authorRole = currentPost.authorRole || '';
const authorBio = currentPost.authorBio || '';
const authorAvatar = currentPost.authorAvatar;
const authorSocial = currentPost.authorSocial;
const authorPagePath = currentPost.authorSlug ? `/${lang}/authors/${currentPost.authorSlug}` : undefined;
const categoryName = currentPost.categoryName;
const tags = currentPost.tags;
const keyTakeaways = currentPost.keyTakeaways;
const publishedDate = currentPost.publishedDate;
const modifiedDate = currentPost.modifiedDate;
const readingTime = currentPost.readingTime;
const articleContent = await getLocalizedPostContent(post.data.slug, lang);

// Générer un slug à partir d'un texte (gère les accents français)
function slugify(text: string): string {
	return text
		.toLowerCase()
		.normalize('NFD')                     // Décompose les accents (é → e + ́)
		.replace(/[\u0300-\u036f]/g, '')      // Supprime les diacritiques
		.replace(/[^a-z0-9]+/g, '-')          // Remplace les non-alphanumériques par -
		.replace(/(^-|-$)/g, '');             // Supprime les - en début/fin
}

// Extraire les titres H2 pour le sommaire (rendu côté serveur pour SEO)
function extractHeadings(content: string): { id: string; text: string }[] {
	const headingRegex = /^## (.+)$/gm;
	const headings: { id: string; text: string }[] = [];
	let match;
	while ((match = headingRegex.exec(content)) !== null) {
		const text = match[1];
		const id = slugify(text);
		headings.push({ id, text });
	}
	return headings;
}

const tableOfContents = extractHeadings(articleContent);

// Articles connexes (même catégorie, excluant l'article actuel)
const relatedPosts = allLocalizedPosts
	.filter((entry) => entry.entry.data.slug !== post.data.slug && entry.categorySlug === currentPost.categorySlug)
	.slice(0, 3)
	.map((entry) => ({
		slug: entry.slug,
		title: entry.title,
		image: entry.featuredImage,
		imageAlt: entry.featuredImageAlt,
		readingTime: entry.readingTime,
	}));

// Parser le markdown simplifié
function parseMarkdown(content: string): string {
	if (!content) return '';

	// Normaliser les fins de ligne
	let html = content.replace(/\r\n/g, '\n');

	// Blocs de code avec langage (traiter en premier pour protéger le contenu)
	html = html.replace(/```(\w+)?\n([\s\S]*?)```/g, (_, lang, code) => {
		const escaped = code.trim()
			.replace(/&/g, '&amp;')
			.replace(/</g, '&lt;')
			.replace(/>/g, '&gt;');
		return `\n<div class="pb-10 sm:pb-16 border-b border-lines"><pre class="bg-bg-light p-4 overflow-x-auto text-[1rem]"><code class="language-${lang || 'text'}">${escaped}</code></pre></div>\n`;
	});

	// Séparer en blocs par lignes vides
	const blocks = html.split(/\n\n+/);
	let isSourcesSection = false;

	const processedBlocks = blocks.map(block => {
		block = block.trim();
		if (!block) return '';

		// Déjà du HTML (blocs de code)
		if (block.startsWith('<div') || block.startsWith('<ul') || block.startsWith('<ol')) {
			return block;
		}

		// Titres H2 avec id pour TOC
		if (block.startsWith('## ')) {
			const title = block.slice(3);
			const id = slugify(title);
			isSourcesSection = ['sources', 'references'].includes(id);
			if (isSourcesSection) {
				return `<h2 class="text-[1.375rem] md:text-[32px] mt-24 mb-10 scroll-mt-24" id="${id}">${applyInlineFormatting(title)}</h2>`;
			}
			return `<h2 class="text-[1.5rem] md:text-[32px] leading-tight mt-24 sm:mt-24 mb-10 sm:mb-10 scroll-mt-24" id="${id}">${applyInlineFormatting(title)}</h2>`;
		}

		// Titres H3
		if (block.startsWith('### ')) {
			const title = block.slice(4);
			isSourcesSection = false;
			return `<h3 class="text-[1.5rem] mt-16 mb-10">${applyInlineFormatting(title)}</h3>`;
		}

		// Listes à puces (bloc qui commence par - ou *)
		if (block.match(/^[-*] /m)) {
			const items = block.split('\n')
				.filter(line => line.match(/^[-*] /))
				.map(line => isSourcesSection
					? `<li class="flex gap-4 py-6 first:pt-0 last:pb-0 leading-relaxed"><span class="section-label mt-1">/</span><span>${applyInlineFormatting(line.slice(2))}</span></li>`
					: `<li class="ml-4">${applyInlineFormatting(line.slice(2))}</li>`)
				.join('\n');
			if (isSourcesSection) {
				return `<ul class="flex flex-col divide-y divide-lines text-[1.125rem]">${items}</ul>`;
			}
				return `<ul class="list-disc list-outside flex flex-col gap-10 py-10 border-t border-b border-lines mb-6 pl-4">${items}</ul>`;
		}

		// Paragraphe normal
		isSourcesSection = false;
			return `<p class="mb-10 text-[1.125rem] leading-relaxed">${applyInlineFormatting(block)}</p>`;
	});

	return processedBlocks.filter(b => b).join('\n\n');
}

// Appliquer le formatage inline (gras, italique, liens, code)
function applyInlineFormatting(text: string): string {
	let result = text;

	// Code inline (avant gras/italique pour éviter les conflits)
	result = result.replace(/`([^`]+)`/g, '<code class="px-1.5 py-0.5 bg-lines rounded text-[0.875em]">$1</code>');

	// Gras (font-medium au lieu de bold)
	result = result.replace(/\*\*([^*]+)\*\*/g, '<strong class="font-medium">$1</strong>');

	// Italique
	result = result.replace(/\*([^*]+)\*/g, '<em>$1</em>');

	// Liens
	result = result.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" title="$1" class="underline-hover">$1</a>');

	return result;
}

// Formater la date
function formatDate(date: Date, locale: string): string {
	return new Intl.DateTimeFormat(locale === 'fr' ? 'fr-BE' : 'en-US', {
		day: 'numeric',
		month: 'long',
		year: 'numeric',
	}).format(new Date(date));
}

// Slug localisé
const currentSlug = currentPost.slug;
const alternateSlug = currentPost.alternateSlug;
const switchLang = lang === 'fr' ? 'en' : 'fr';
const breadcrumbAriaLabel = t.blogPage.breadcrumbAriaLabel;
const breadcrumbItems = [
	{ label: t.blogPage.breadcrumbHome, href: `/${lang}` },
	{ label: 'Blog', href: getBlogIndexHref(lang) },
	{ label: `${title.trim().split(/\s+/)[0]}...` },
];
const authorIntroLabel = t.blogPage.authorIntro;
const heroAuthorLabel = authorRole ? `${authorName} - ${authorRole}` : authorName;
const readingTimeLabel = t.blogPage.minRead;
const updatedDate = modifiedDate || publishedDate;

// URL de partage
const siteUrl = (Astro.site?.toString() || 'https://hordeagence.com').replace(/\/$/, '');
const articleUrl = `${siteUrl}/${lang}/blog/${currentSlug}`;
const authorUrl = authorPagePath ? `${siteUrl}${authorPagePath}` : undefined;
const shareUrl = articleUrl;
const tagShareLinkClasses = 'underline-hover w-fit inline-flex text-[1.125rem] leading-[1.375rem] font-[375] text-black cursor-pointer';
const authorSameAs = [
	authorSocial?.twitter ? `https://twitter.com/${authorSocial.twitter}` : null,
	authorSocial?.linkedin || null,
	authorSocial?.github ? `https://github.com/${authorSocial.github}` : null,
].filter(Boolean);
// URL pour le switch de langue (avec le slug de l'autre langue)
const alternateUrl = `${siteUrl}/${switchLang}/blog/${alternateSlug}`;
const imageUrl = currentPost.featuredImage.src?.startsWith('http')
	? currentPost.featuredImage.src
	: `${siteUrl}${currentPost.featuredImage.src}`;

// Schema.org JSON-LD
const schemaOrg = {
	"@context": "https://schema.org",
	"@graph": [
		// BlogPosting
		{
			"@type": "BlogPosting",
			"@id": `${articleUrl}#article`,
			"headline": title,
			"description": seoDescription,
			"image": imageUrl,
			"datePublished": publishedDate.toISOString(),
			"dateModified": modifiedDate ? modifiedDate.toISOString() : publishedDate.toISOString(),
			"author": {
				"@type": "Person",
				"name": authorName,
				"jobTitle": authorRole,
				...(authorUrl && { "url": authorUrl }),
				...(authorAvatar && { "image": `${siteUrl}${authorAvatar.src}` }),
				...(authorSameAs.length > 0 && { "sameAs": authorSameAs }),
			},
			"publisher": {
				"@type": "Organization",
				"@id": `${siteUrl}#organization`,
				"name": "Horde Agence",
				"url": siteUrl,
				"logo": {
					"@type": "ImageObject",
					"url": `${siteUrl}/images/logo.svg`
				}
			},
			"mainEntityOfPage": {
				"@type": "WebPage",
				"@id": articleUrl
			},
				"articleSection": categoryName,
				"keywords": tags.join(", "),
				"wordCount": articleContent.split(/\s+/).length,
				"timeRequired": `PT${readingTime}M`,
				"abstract": excerpt,
				"inLanguage": lang === 'fr' ? 'fr-BE' : 'en-US'
			},
			...(keyTakeaways.length > 0
				? [{
					"@type": "ItemList",
					"@id": `${articleUrl}#takeaways`,
					"name": t.blogPage.keyTakeaways,
					"itemListElement": keyTakeaways.map((item: string, index: number) => ({
						"@type": "ListItem",
						"position": index + 1,
						"name": item,
					})),
				}]
				: []),
			// BreadcrumbList
			{
			"@type": "BreadcrumbList",
			"@id": `${articleUrl}#breadcrumb`,
			"itemListElement": [
				{
					"@type": "ListItem",
					"position": 1,
					"name": t.blogPage.breadcrumbHome,
					"item": `${siteUrl}/${lang}`
				},
				{
					"@type": "ListItem",
					"position": 2,
					"name": "Blog",
					"item": `${siteUrl}/${lang}/blog`
				},
				{
					"@type": "ListItem",
					"position": 3,
					"name": title,
					"item": articleUrl
				}
			]
		}
	]
};
---

<Layout
	lang={lang}
	alternateUrl={alternateUrl}
	title={title}
	description={seoDescription}
	ogType="article"
	publishedTime={publishedDate.toISOString()}
	modifiedTime={modifiedDate?.toISOString()}
	author={authorName}
	authorUrl={authorUrl}
	variant="light"
	headerVariant="dark"
	showContainerLines={false}
>
	<!-- Schema.org JSON-LD -->
	<script is:inline type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />

	<div class="fixed inset-0 bg-bg -z-10" aria-hidden="true"></div>
	<article id="page-content" class="relative z-10 bg-bg">
		<div class="full-width-white-bg">
		<div class="relative left-1/2 w-screen -translate-x-1/2 bg-black">
		<HeroStructure
			class="relative z-0"
			background="dark"
			showHorizontalLine={false}
			showVerticalLine={true}
			showObliqueLines={false}
			ariaLabelledby="blog-post-intro"
			breadcrumbItems={breadcrumbItems}
			breadcrumbAriaLabel={breadcrumbAriaLabel}
			spacingClass="pt-16 pb-0 sm:pt-32 lg:pt-40"
			contentClass="sm:h-[426px] lg:h-[490px]"
		>
			<div class="w-full sm:flex sm:flex-col sm:gap-8">
				<div class="flex w-full sm:h-1/2 sm:items-end">
					<div class="w-full sm:flex sm:justify-between">
						<div class="relative z-10 flex max-w-[450px] flex-col gap-4 sm:gap-8 lg:w-1/2 lg:max-w-[700px]">
								<h1
									id="blog-post-intro"
									class="text-[1.5rem] leading-tight sm:text-[2rem] lg:text-[2.5rem]"
								>
									<span class="page-hero-reveal-clip">
										<span class="page-hero-reveal-line" style="--hero-reveal-order: 0">{title}</span>
									</span>
								</h1>
						</div>
						<svg class="page-hero-heading-svg hidden sm:block" width="47" height="20" viewBox="0 0 47 20" fill="none" xmlns="http://www.w3.org/2000/svg">
							<rect width="7" height="20" transform="matrix(1 4.37114e-08 8.74228e-08 -1 0 20)" fill="#F4F1F8"/>
							<rect width="7" height="20" transform="matrix(1 4.37114e-08 8.74228e-08 -1 14 20)" fill="#F4F1F8"/>
							<g class="decorative-diagonal-spin">
								<rect width="7" height="20" transform="matrix(0.707107 0.707107 0.707107 -0.707107 27.4531 14.5938)" fill="#F4F1F8"/>
							</g>
						</svg>
					</div>
				</div>

				<div class="sm:h-1/2 md:flex md:justify-end">
					<div class="relative z-10 mt-8 flex flex-col sm:mt-0 sm:w-full sm:flex-row lg:mt-0 md:w-1/2 md:self-end md:justify-end lg:gap-20">
						<p class="relative h-fit sm:w-fit list-[square] pl-5 pr-10 text-[1.25rem] sm:mt-0 sm:pr-24 md:pr-0">
							<span class="list-item">
								<span class="inline-grid gap-2 sm:grid-cols-[auto_1fr] sm:gap-8">
									<span>{authorIntroLabel}:</span>
									{authorPagePath ? (
										<a href={authorPagePath} class="transition-opacity max-w-[250px] sm:mx-8 duration-200 hover:opacity-65">
											{heroAuthorLabel}
										</a>
									) : (
										<span>{heroAuthorLabel}</span>
									)}
								</span>
							</span>
						</p>
						<svg
							class="absolute right-0 bottom-0 z-10 text-current"
							width="8"
							height="35"
							viewBox="0 0 8 35"
							fill="none"
							xmlns="http://www.w3.org/2000/svg"
							aria-hidden="true"
						>
							<path
								d="M1.95527 35L-4.1008e-05 35C2.89218 30.1433 5.05117 24.8452 5.05117 17.4197C5.05117 10.1548 2.89219 4.85665 -3.78207e-05 -6.1196e-07L1.95527 -4.47859e-07C4.76602 4.0539 7.29163 10.1548 7.29163 17.4197C7.29163 24.9255 4.76602 30.9461 1.95527 35Z"
								fill="currentColor"
							/>
						</svg>
					</div>
				</div>
			</div>
		</HeroStructure>

		<div class="relative z-20 isolate text-button-white lg:-mt-54">
			<div class="relative z-20 mx-auto max-w-[1320px] px-(--gutter) lg:px-0">
				<div class="blog-post-meta-block text-[1.125rem] pt-4 sm:pt-50 md:pt-16 text-button-white flex lg:flex-col-reverse justify-between items-end lg:items-start">
					<div class="lg:mt-8">
						<p>
							<span>{t.blogPage.publishedOn}</span>{" "}
							<time datetime={publishedDate.toISOString()}>{formatDate(publishedDate, lang)}</time>
						</p>
						<p>
							<span>{t.blogPage.updatedOn}</span>{" "}
							<time datetime={updatedDate.toISOString()}>{formatDate(updatedDate, lang)}</time>
						</p>
					</div>
					<p>{readingTime} {readingTimeLabel}</p>
				</div>

				<!-- Image principale -->
				<div class="relative z-30 mt-16 sm:mt-6 md:mt-16 lg:mt-20 mb-10 flex h-[330px] md:h-[455px] max-w-[1000px] items-center justify-center overflow-hidden bg-white sm:mb-24 mx-auto">
					<div class="pointer-events-none absolute left-1/2 top-1/2 z-0 h-full w-px -translate-x-1/2 -translate-y-1/2 bg-lines" aria-hidden="true"></div>
					<div class="pointer-events-none absolute left-1/2 top-1/2 z-0 h-px w-full -translate-x-1/2 -translate-y-1/2 bg-lines" aria-hidden="true"></div>
					<div class="pointer-events-none absolute left-1/2 top-1/2 z-0 h-px w-[120%] -translate-x-1/2 -translate-y-1/2 rotate-45 bg-lines" aria-hidden="true"></div>
					<div class="pointer-events-none absolute left-1/2 top-1/2 z-0 h-px w-[120%] -translate-x-1/2 -translate-y-1/2 -rotate-45 bg-lines" aria-hidden="true"></div>
					<figure class="relative z-10 aspect-square w-[250px] md:w-[330px] bg-black flex justify-center items-center">
						<Image
							src={currentPost.featuredImage}
							alt={featuredImageAlt}
							class="w-full h-auto object-cover"
							widths={[400, 800, 1200, 1600]}
							sizes="(max-width: 768px) 100vw, 768px"
							loading="eager"
							fetchpriority="high"
							decoding="async"
							format="webp"
							quality={85}
						/>
					</figure>
				</div>
			</div>
		</div>
		</div>

		<!-- Layout 2 colonnes: Contenu + Sidebar -->
		<div>
			<!-- Contenu principal -->
			<div class="lg:flex-1 max-w-[1000px] mx-auto">
				{keyTakeaways.length > 0 && (
					<section class="mt-10 sm:mt-16" aria-label={t.blogPage.keyTakeaways}>
							<h2 class="text-[1.375rem] md:text-[32px] mb-10">{t.blogPage.keyTakeaways}</h2>
						<ul class="flex flex-col divide-y divide-lines text-[1.125rem]">
							{keyTakeaways.map((item: string) => (
								<li class="flex gap-4 py-6 first:pt-0 last:pb-0 leading-relaxed">
									<span class="section-label mt-1">/</span>
									<span>{item}</span>
								</li>
							))}
						</ul>
					</section>
				)}

				<!-- Sommaire (rendu côté serveur pour SEO) -->
				{tableOfContents.length > 0 && (
					<nav class="mt-24" aria-label={t.blogPage.tableOfContents}>
							<h2 class="text-[1.375rem] md:text-[32px] mb-8">{t.blogPage.tableOfContents}</h2>
							<ol class="flex flex-col gap-6">
								{tableOfContents.map((heading, index) => (
									<li>
										<a
											href={`#${heading.id}`}
											class="toc-service-link flex items-center gap-10"
											title={heading.text}
										>
											<span class="text-[1.125rem]">{String(index + 1)}/</span>
											<span class="toc-service-link__label flex-1">
												<span class="toc-service-link__base">{heading.text}</span>
												<span class="toc-service-link__overlay" aria-hidden="true">{heading.text}</span>
											</span>
											<span class="toc-service-link__icon shrink-0 text-[18px]">
												<span class="toc-service-link__base">(→)</span>
												<span class="toc-service-link__overlay" aria-hidden="true">(→)</span>
											</span>
										</a>
									</li>
								))}
						</ol>
					</nav>
				)}

				<!-- Extrait / Chapô -->
				<div class="relative my-24">
					<svg class="h-8 absolute top-0 left-0" viewBox="0 0 6 30" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M4.39106 0H6C3.62011 4.16285 1.84358 8.70413 1.84358 15.0688C1.84358 21.2959 3.62011 25.8372 6 30H4.39106C2.07821 26.5252 0 21.2959 0 15.0688C0 8.63532 2.07821 3.47477 4.39106 0Z" fill="#16191B"/>
					</svg>
					<p class="text-[1.5rem] leading-[2rem] px-8 indent-16 ">
						{excerpt}
					</p>
					<svg class="h-8 absolute bottom-0 right-0" viewBox="0 0 7 30" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M1.67598 30L-9.53674e-07 30C2.47905 25.8372 4.32961 21.2959 4.32961 14.9312C4.32961 8.70413 2.47905 4.16284 8.80026e-07 -7.81488e-07L1.67598 -5.71927e-07C4.0852 3.47477 6.25 8.70413 6.25 14.9312C6.25 21.3647 4.0852 26.5252 1.67598 30Z" fill="#16191B"/>
					</svg>
				</div>

				<!-- Contenu de l'article -->
				<div class="prose prose-lg text-[1.375rem] max-w-none mb-16" set:html={parseMarkdown(articleContent)} />
				{!articleContent && (
					<p class="text-black/60 italic">{t.blogPage.emptyContent}</p>
				)}

			</div>
			<div class="max-w-[1000px] mx-auto lg:max-w-none">
				<!-- Tags + Partage (2 colonnes sur lg) -->
				<div class="flex sm:justify-between lg:gap-16 pt-10 sm:pt-16 lg:pt-24 pb-24">
					<!-- Tags -->
					{tags.length > 0 && (
						<div class="lg:mb-0 lg:flex-1 sm:max-w-[300px]">
							<h2 class="section-label mb-10">{t.blogPage.tags}</h2>
							<div class="flex flex-wrap gap-5">
								{tags.map((tag: string) => (
									<a
										href={getBlogTagHref(tag, lang)}
										class={tagShareLinkClasses}
										title={tag}
									>
										{tag}
									</a>
								))}
							</div>
						</div>
					)}

					<!-- Partage -->
					<div class="lg:flex-1 flex flex-col items-end">
						<h2 class="section-label mb-10">{t.blogPage.shareArticle}</h2>
						<div class="flex flex-wrap sm:flex-col sm:flex-nowrap justify-end sm:items-end gap-5 ">
							<a
								href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(shareUrl)}&text=${encodeURIComponent(title)}`}
								target="_blank"
								rel="noopener noreferrer"
								class={tagShareLinkClasses}
								title="Twitter"
							>
								Twitter
							</a>
							<a
								href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrl)}`}
								target="_blank"
								rel="noopener noreferrer"
								class={tagShareLinkClasses}
								title="LinkedIn"
							>
								LinkedIn
							</a>
							<button
								type="button"
								class={`copy-link bg-transparent p-0 ${tagShareLinkClasses}`}
								data-url={shareUrl}
							>
								<span>{t.blogPage.copyLink}</span>
							</button>
						</div>
					</div>
				</div>
			</div>
		</div>
		</div>

			<div class="max-w-[1000px] mt-16 sm:mt-24 mx-auto lg:max-w-none">
				<!-- Bio Auteur -->
				{(authorBio || authorAvatar || authorSocial || authorPagePath) && (
					<div class="flex justify-between">
						<h2 class="text-[1.25rem] sm:text-[1.5rem] mb-10">{t.blogPage.authorIntro} :</h2>
						<div class="flex flex-col items-end sm:items-start gap-6 md:w-1/2 lg:w-[430px]">
							<p class="sm:text-[1.5rem]">Nicolas Prémont</p>
							{authorSocial && (
								<div class="flex gap-5">
									{authorSocial.twitter && (
										<a href={`https://twitter.com/${authorSocial.twitter}`} target="_blank" rel="noopener noreferrer" class="underline-hover text-black/60 hover:text-black transition-colors" title="Twitter">
											Twitter
										</a>
									)}
									{authorSocial.linkedin && (
										<a href={authorSocial.linkedin} target="_blank" rel="noopener noreferrer" class="underline-hover text-black/60 hover:text-black transition-colors" title="LinkedIn">
											LinkedIn
										</a>
									)}
									{authorSocial.github && (
										<a href={`https://github.com/${authorSocial.github}`} target="_blank" rel="noopener noreferrer" class="underline-hover text-black/60 hover:text-black transition-colors" title="GitHub">
											GitHub
										</a>
									)}
								</div>
							)}
						</div>
					</div>
					<div class="mt-16">
						<div class="md:flex lg:justify-between">
							{authorBio && (
								<p class="md:w-1/2">{t.blogPage.authorBioLabel}: </p>
								<p class="leading-relaxed mt-10 md:mt-0 md:w-1/2 lg:w-[430px]">
									{authorBio}
								</p>
							)}
						</div>
						{/* Desktop (md+): photo à gauche, nom/rôle inline + description à droite */}
					</div>
				)}
				</div>

		<!-- Articles connexes -->
		{relatedPosts.length > 0 && (
			<section class="mt-10 sm:mt-16 pt-24 border-t border-lines">
				<h2 class=" text-[1.5rem] md:text-[2rem] mb-10">{t.blogPage.relatedArticles}</h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
					{relatedPosts.map((related) => (
						<a href={getBlogPostHref(related.slug, lang)} class="group" title={related.title}>
							<div class="overflow-hidden mb-4 aspect-square">
								<Image
									src={related.image}
									alt={related.imageAlt}
									class="w-full h-full object-cover transition-transform duration-400 group-hover:scale-105"
									widths={[250, 400]}
									sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
									loading="lazy"
									decoding="async"
									format="webp"
									quality={75}
								/>
							</div>
							<h3 class="text-[1.125rem] leading-tight">{related.title}</h3>
							<p class="text-[0.875rem] font-mono uppercase text-black/90 mt-5">{related.readingTime} {t.blogPage.minRead}</p>
						</a>
					))}
				</div>
			</section>
		)}

		<!-- Bouton retour -->
		<nav class="mt-16 mb-10 flex justify-end max-w-[1000px] mx-auto lg:max-w-none">
			<a
				href={getBlogIndexHref(lang)}
				class="group relative overflow-hidden font-mono text-[1rem] leading-none uppercase py-6 px-5 flex justify-center w-full md:w-fit border border-lines-dark bg-black text-button-white transition-colors duration-300 ease-in-out cursor-pointer"
				title={t.blogPage.allArticles}
			>
				<span class="absolute inset-0 bg-bg translate-x-[calc(-100%-1px)] group-hover:translate-x-0 transition-transform duration-400 ease-[cubic-bezier(0.25,0.46,0.45,0.94)]"></span>
				<span class="relative z-10 text-button-white group-hover:text-black transition-colors duration-300">
					{t.blogPage.allArticles}
				</span>
			</a>
		</nav>
	</article>

	<Footer lang={lang} hideOverflow={false} />
</Layout>

	<style>
		.toc-service-link {
			position: relative;
			isolation: isolate;
		}

		.toc-service-link::before {
			content: "";
			position: absolute;
			top: -6px;
			right: -10px;
			bottom: -6px;
			left: -10px;
			z-index: -1;
			background-color: var(--color-black);
			transform: scaleY(0);
			transform-origin: center bottom;
		}

		.toc-service-link__label,
		.toc-service-link__icon {
			position: relative;
			z-index: 1;
			display: block;
			overflow: hidden;
			margin-block: -0.05em;
			padding-block: 0.05em;
		}

		.toc-service-link__icon {
			display: inline-flex;
		}

		.toc-service-link__base,
		.toc-service-link__overlay {
			display: block;
			transition: transform 0.15s ease-out;
		}

		.toc-service-link__overlay {
			position: absolute;
			inset: 0.05em 0;
			color: var(--color-button-white);
			transform: translateY(110%);
		}

		@media (hover: hover) {
			.toc-service-link::before {
				transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
			}

			.toc-service-link:hover::before {
				transform: scaleY(1);
			}

			.toc-service-link:hover {
				color: var(--color-button-white);
			}

			.toc-service-link:hover .toc-service-link__base {
				transform: translateY(-110%);
			}

			.toc-service-link:hover .toc-service-link__overlay {
				transform: translateY(0);
			}
		}

		/* Prose styles */
		.prose h2 {
		scroll-margin-top: 6rem;
	}

	.prose a {
		text-decoration: none;
	}

	.prose blockquote {
		border-left: 2px solid var(--color-lines);
		padding-left: 1.5rem;
		font-style: italic;
		color: rgba(0, 0, 0, 0.7);
	}

	.prose code {
		background: var(--color-lines);
		padding: 0.125rem 0.375rem;
		border-radius: 0.25rem;
		font-size: 0.875em;
	}

	.prose pre {
		background: var(--color-black);
		color: var(--color-button-white);
		padding: 1.5rem;
		overflow-x: auto;
		margin: 1.5rem 0;
	}

	.prose pre code {
		background: none;
		padding: 0;
	}

	.prose li > p:last-child {
		margin-bottom: 0;
	}

	.prose img {
		width: 100%;
		height: auto;
		margin: 2rem 0;
	}

	/* TOC active state */
	#toc a {
		display: block;
		padding: 0.5rem 0;
		color: rgba(0, 0, 0, 0.6);
		border-left: 2px solid transparent;
		padding-left: 1rem;
		margin-left: -1rem;
		transition: all 0.2s;
	}

	#toc a:hover,
	#toc a.active {
		color: var(--color-black);
		border-left-color: var(--color-black);
	}
</style>

<script>
	function initTOC() {
		const toc = document.getElementById('toc');
		const headings = document.querySelectorAll('.prose h2');

		if (!toc || headings.length === 0) return;

		// Générer la TOC
		toc.innerHTML = '';
		headings.forEach((heading) => {
			const li = document.createElement('li');
			const a = document.createElement('a');
			a.href = `#${heading.id}`;
			a.textContent = heading.textContent;
			li.appendChild(a);
			toc.appendChild(li);
		});

		// Highlight active heading on scroll
		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					const id = entry.target.id;
					const tocLink = toc.querySelector(`a[href="#${id}"]`);
					if (tocLink) {
						if (entry.isIntersecting) {
							toc.querySelectorAll('a').forEach((a) => a.classList.remove('active'));
							tocLink.classList.add('active');
						}
					}
				});
			},
			{ rootMargin: '-100px 0px -80% 0px' }
		);

		headings.forEach((heading) => observer.observe(heading));
	}

	function initCopyLink() {
		const copyButtons = document.querySelectorAll('.copy-link');
		copyButtons.forEach((btn) => {
			btn.addEventListener('click', async () => {
				const url = (btn as HTMLElement).dataset.url;
				if (url) {
					await navigator.clipboard.writeText(url);
					const textSpan = btn.querySelector('span:last-child');
					if (textSpan) {
						const originalText = textSpan.textContent;
						textSpan.textContent = '✓';
						setTimeout(() => {
							textSpan.textContent = originalText;
						}, 2000);
					}
				}
			});
		});
	}

	initTOC();
	initCopyLink();
	document.addEventListener('astro:after-swap', () => {
		initTOC();
		initCopyLink();
	});
</script>
