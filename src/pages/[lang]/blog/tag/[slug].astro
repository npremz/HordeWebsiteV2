---
import Layout from '../../../../layouts/Layout.astro';
import Footer from '../../../../components/Footer.astro';
import BlogListingPage from '../../../../components/blog/BlogListingPage.astro';
import { SUPPORTED_LOCALES, type Locale, useTranslations } from '../../../../i18n';
import {
  getLocalizedCategories,
  getLocalizedPosts,
  getLocalizedPostsByTag,
  getLocalizedTags,
  getAlternateTagSlug,
  getBlogCategoryHref,
  getBlogIndexHref,
  getBlogTagHref,
  slugifyTag,
} from '../../../../lib/content/blog';

export const prerender = true;

export async function getStaticPaths() {
  const paths = await Promise.all(
    SUPPORTED_LOCALES.map(async (lang) => {
      const tags = await getLocalizedTags(lang);

      return tags.map((tag) => ({
        params: { lang, slug: slugifyTag(tag) },
        props: { tag, lang },
      }));
    }),
  );

  return paths.flat();
}

const { tag, lang } = Astro.props as { tag: string; lang: Locale };
const t = useTranslations(lang);
const switchLang: Locale = lang === 'fr' ? 'en' : 'fr';
const alternateTagSlug = await getAlternateTagSlug(tag, lang);
const alternateUrl = alternateTagSlug
  ? new URL(getBlogTagHref(alternateTagSlug, switchLang), Astro.site).href
  : undefined;
const [categories, allPosts, posts] = await Promise.all([
  getLocalizedCategories(lang),
  getLocalizedPosts(lang),
  getLocalizedPostsByTag(tag, lang),
]);

const usedCategorySlugs = new Set(allPosts.map((post) => post.categorySlug));
const filters = [
  { href: getBlogIndexHref(lang), label: t.blogPage.allLabel, current: false },
  ...categories
    .filter((category) => usedCategorySlugs.has(category.baseSlug))
    .map((category) => ({
      href: getBlogCategoryHref(category.slug, lang),
      label: category.name,
      current: false,
    })),
];

function withTag(template: string): string {
  return template.replace('{tag}', tag);
}

const pageTitle = withTag(t.blogPage.tagPageTitle);
const pageDescription = withTag(t.blogPage.tagPageDescription);
const heading = withTag(t.blogPage.tagPageHeading);
const robots = posts.length > 2 ? 'index, follow' : 'noindex, follow';
---

<Layout
  lang={lang}
  title={pageTitle}
  description={pageDescription}
  alternateUrl={alternateUrl}
  robots={robots}
  variant="light"
  headerVariant="dark"
  showContainerLines={false}
>
  <BlogListingPage
    lang={lang}
    posts={posts}
    heading={heading}
    filters={filters}
  />

  <div class="relative z-0 full-width-white-bg">
    <Footer lang={lang} variant="light" hideOverflow={false} />
  </div>
</Layout>
