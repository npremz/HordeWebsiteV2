---
import Layout from '../../../../layouts/Layout.astro';
import Footer from '../../../../components/Footer.astro';
import BlogListingPage from '../../../../components/blog/BlogListingPage.astro';
import { SUPPORTED_LOCALES, type Locale, useTranslations } from '../../../../i18n';
import {
  type CategoryEntry,
  getBlogCategoryHref,
  getBlogIndexHref,
  getCategories,
  getLocalizedCategories,
  getLocalizedPosts,
  getLocalizedPostsByCategory,
  localizeCategory,
} from '../../../../lib/content/blog';

export const prerender = true;

export async function getStaticPaths() {
  const categories = await getCategories();

  return SUPPORTED_LOCALES.flatMap((lang) =>
    categories.map((category) => {
      const localizedCategory = localizeCategory(category, lang);

      return {
        params: { lang, slug: localizedCategory.slug },
        props: { category, lang },
      };
    }),
  );
}

const { category, lang } = Astro.props as { category: CategoryEntry; lang: Locale };
const t = useTranslations(lang);
const localizedCategory = localizeCategory(category, lang);
const switchLang: Locale = lang === 'fr' ? 'en' : 'fr';
const alternateCategory = localizeCategory(category, switchLang);
const alternateUrl = new URL(getBlogCategoryHref(alternateCategory.slug, switchLang), Astro.site).href;
const [categories, allPosts, posts] = await Promise.all([
  getLocalizedCategories(lang),
  getLocalizedPosts(lang),
  getLocalizedPostsByCategory(category.data.slug, lang),
]);

const usedCategorySlugs = new Set(allPosts.map((post) => post.categorySlug));
const filters = [
  { href: getBlogIndexHref(lang), label: t.blogPage.allLabel, current: false },
  ...categories
    .filter((item) => usedCategorySlugs.has(item.baseSlug))
    .map((item) => ({
      href: getBlogCategoryHref(item.slug, lang),
      label: item.name,
      current: item.baseSlug === category.data.slug,
    })),
];

const pageTitle = `${localizedCategory.name} | ${t.blogPage.listingTitleSuffix}`;
const pageDescription =
  localizedCategory.description ||
  `${t.blogPage.categoryArticles} ${localizedCategory.name}.`;
const heading = t.blogPage.categoryPageHeading.replace('{category}', localizedCategory.name);
const robots = posts.length > 2 ? 'index, follow' : 'noindex, follow';
---

<Layout
  lang={lang}
  title={pageTitle}
  description={pageDescription}
  alternateUrl={alternateUrl}
  robots={robots}
  variant="light"
  headerVariant="dark"
  showContainerLines={false}
>
  <BlogListingPage
    lang={lang}
    posts={posts}
    heading={heading}
    filters={filters}
  />

  <div class="relative z-0 full-width-white-bg">
    <Footer lang={lang} variant="light" hideOverflow={false} />
  </div>
</Layout>
